---
// ═══════════════════════════════════════════════════
// CLIENT AUDIT REPORT — BLANK TEMPLATE
// ═══════════════════════════════════════════════════
// 1. Copy: cp src/pages/clients/_template.astro src/pages/clients/client-name.astro
// 2. Fill in client info, report data, search terms, tables below
// 3. Build: npm run build
// 4. Push: git add . && git commit -m "Add [Client] audit" && git push origin main
// 5. Live at: scalingsmb.com/clients/client-name/
// ═══════════════════════════════════════════════════

import AuditLayout from '../../layouts/AuditLayout.astro';

const client = {
	name: 'Client Name',
	url: 'https://clientwebsite.com',
	tagline: 'Their business tagline',
	service: 'Description of their service',
};

const report = {
	period: 'Month 1 – Month DD, YYYY',
	monthlyAdSpend: 0,
	monthlyAdConversions: 0,
	monthlyAdAvgCpc: 0,
	currency: 'HKD',
	organicClicks: 0,
	organicImpressions: 0,
};
---

<AuditLayout client={client} period={report.period}>

	<section slot="content">
		<!-- Executive Summary -->
		<section class="section">
			<div class="wrapper">
				<h2><span class="section-icon">📋</span> Executive Summary</h2>
				<div class="alert alert-critical">
					<strong>Key Finding:</strong> Write the headline finding here — specific and quantified.
				</div>
				<div class="kpi-grid">
					<div class="kpi-card"><span class="kpi-value">{report.monthlyAdSpend.toLocaleString()} {report.currency}<small>/mo</small></span><span class="kpi-label">Monthly Ad Spend</span></div>
					<div class="kpi-card"><span class="kpi-value">{report.monthlyAdConversions}</span><span class="kpi-label">Tracked Conversions</span></div>
					<div class="kpi-card"><span class="kpi-value">{report.monthlyAdAvgCpc} {report.currency}</span><span class="kpi-label">Avg Cost Per Click</span></div>
					<div class="kpi-card"><span class="kpi-value">{report.organicClicks}</span><span class="kpi-label">Organic Clicks (90 days)</span></div>
				</div>
			</div>
		</section>

		<!-- About -->
		<section class="section">
			<div class="wrapper">
				<h2><span class="section-icon">🏢</span> About {client.name}</h2>
				<div class="content-card">
					<p>Describe their business.</p>
					<div class="info-grid">
						<div><strong>Service:</strong> {client.service}</div>
						<div><strong>Website:</strong> <a href={client.url} target="_blank">{client.url}</a></div>
						<div><strong>Differentiator:</strong> Key competitive advantage</div>
					</div>
				</div>
			</div>
		</section>

		<!-- Methodology -->
		<section class="section">
			<div class="wrapper">
				<h2><span class="section-icon">🔬</span> Audit Methodology</h2>
				<p>This audit uses the <strong>Scaling SMB 9-Phase Client Onboarding Audit</strong> methodology.</p>
				<div class="methodology-steps">
					<div class="step"><span class="step-num">1</span> Conversion Tracking</div>
					<div class="step"><span class="step-num">2</span> Account Structure</div>
					<div class="step"><span class="step-num">3</span> Keywords &amp; Search Terms</div>
					<div class="step"><span class="step-num">4</span> Ad Copy &amp; Creative</div>
					<div class="step"><span class="step-num">5</span> Bidding &amp; Budget</div>
					<div class="step"><span class="step-num">6</span> Audience Targeting</div>
					<div class="step"><span class="step-num">7</span> Landing Pages / SEO</div>
					<div class="step"><span class="step-num">8</span> PMax Health</div>
					<div class="step"><span class="step-num">9</span> Roadmap &amp; Recommendations</div>
				</div>
			</div>
		</section>

		<!-- Google Ads -->
		<section class="section">
			<div class="wrapper">
				<h2><span class="section-icon">📊</span> Google Ads Account Analysis</h2>

				<h3>Account Structure</h3>
				<table class="data-table">
					<thead><tr><th>Campaign</th><th>Type</th><th>Status</th><th>Spend</th><th>Clicks</th><th>Conv.</th><th>Avg CPC</th></tr></thead>
					<tbody>
						<tr><td colspan="7" style="text-align:center;color:var(--text-muted)">Add campaign data here</td></tr>
					</tbody>
				</table>

				<h3>Spend Distribution</h3>
				<div class="kpi-charts">
					<div class="kpi-chart-row">
						<span class="kpi-chart-label">Campaign name</span>
						<div class="kpi-chart-bar-wrap"><div class="kpi-chart-bar bar-blue" style="width:70%"><span class="kpi-chart-bar-value">{report.currency} X</span></div></div>
						<span class="kpi-chart-val">70%</span>
					</div>
				</div>

				<h3>Key Search Terms</h3>
				<div class="kpi-charts">
					<!-- Bar chart for top search terms -->
				</div>
			</div>
		</section>

		<!-- Recommendations -->
		<section class="section">
			<div class="wrapper">
				<h2><span class="section-icon">🎯</span> Recommendations</h2>
				<div class="rec-list">
					<div class="rec-item">
						<h4>[First Priority Fix]</h4>
						<p>Describe the fix with specifics.</p>
					</div>
					<div class="rec-item">
						<h4>[Second Priority Fix]</h4>
						<p>Describe the fix.</p>
					</div>
				</div>
			</div>
		</section>
	</section>

</AuditLayout>
