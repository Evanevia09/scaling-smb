---
import AuditLayout from '../../layouts/AuditLayout.astro';

const c = {
	name: 'TranspoLink',
	url: 'https://transpolink.net',
	tagline: 'Premier Chauffeur Service in Greater Bay Area',
	service: 'Executive limousine & cross-border chauffeur services (Macau, HK, Mainland China)',
};

const r = {
	period: 'March 1 – June 3, 2026',
	spend: 5020, clicks: 1164, conv: 0, cpc: 4.32,
	ccy: 'HKD',
	organicClicks: 87, organicImpressions: 2986,
};

// Pie chart SVG arc helper
function pieSegment(pct, offset, color) {
	const r = 90, cx = 100, cy = 100;
	const ang = (pct / 100) * 360;
	const rad = (ang - 90) * Math.PI / 180;
	const x = cx + r * Math.cos(rad);
	const y = cy + r * Math.sin(rad);
	const ang2 = (-90) * Math.PI / 180;
	const x2 = cx + r * Math.cos(ang2);
	const y2 = cy + r * Math.sin(ang2);
	const large = ang > 180 ? 1 : 0;
	return `<path d="M${cx},${cy} L${x2},${y2} A${r},${r} 0 ${large},1 ${x},${y} Z" fill="${color}" />`;
}

const maxSearchTermSpend = 110.11;
const searchTerms = [
	{ term: 'macau tour from hong kong', spend: 110.11, clicks: 3, verdict: 'bad' },
	{ term: 'hong kong to macau', spend: 62.57, clicks: 3, verdict: 'bad' },
	{ term: 'direct bus hk to macau', spend: 53.05, clicks: 1, verdict: 'bad' },
	{ term: 'macau to hong kong car', spend: 52.24, clicks: 1, verdict: 'bad' },
	{ term: 'hong kong to macau ferry', spend: 52.18, clicks: 1, verdict: 'bad' },
	{ term: 'how to go macau from hk', spend: 51.18, clicks: 1, verdict: 'bad' },
	{ term: 'macau airport limousine service', spend: 3.95, clicks: 1, verdict: 'good' },
];
const wasteTotal = searchTerms.filter(t => t.verdict === 'bad').reduce((s, t) => s + t.spend, 0);
const wastePct = Math.round(wasteTotal / (r.spend / 4.3) * 100);
const productivePct = 100 - wastePct;
---

<AuditLayout client={{name: c.name, url: c.url, tagline: c.tagline}} period={r.period}>

	<section slot="content">
		<!-- Executive Summary -->
		<section class="section">
			<div class="wrapper">
				<h2><span class="section-icon">📋</span> What We Found</h2>
				<div class="alert alert-critical">
					<strong>Your ads are running, but nobody is booking.</strong> You're spending about {r.spend.toLocaleString()} {r.ccy}/month on Google Ads, and getting <strong>zero tracked bookings</strong> in return. The main reason: your campaign is showing up for people searching for ferry schedules and bus fares — not people looking for a premium chauffeur service. Conversion tracking also needs to be set up so we can actually measure what's working.
				</div>

				<div class="kpi-row">
					<div class="kpi-item"><span class="kpi-num">{r.spend.toLocaleString()} {r.ccy}<small>/mo</small></span><span class="kpi-label">Monthly ad spend</span></div>
					<div class="kpi-item"><span class="kpi-num">0</span><span class="kpi-label">Bookings tracked</span></div>
					<div class="kpi-item"><span class="kpi-num">{r.cpc} {r.ccy}</span><span class="kpi-label">Average cost per click</span></div>
					<div class="kpi-item"><span class="kpi-num">{r.organicClicks}</span><span class="kpi-label">Free clicks (90 days)</span></div>
				</div>
			</div>
		</section>

		<!-- About -->
		<section class="section">
			<div class="wrapper">
				<h2><span class="section-icon">🏢</span> About {c.name}</h2>
				<div class="content-card">
					<p><strong>{c.name}</strong> is a Macau-based premium chauffeur service operating across Macau, Hong Kong, and Mainland China. They provide Toyota Alphard/Vellfire MPVs with 5G Wi-Fi, leather seating, and privacy features. Their clients are executive business travellers, VIP leisure guests, and diplomatic delegations.</p>
					<div class="info-grid">
						<div><strong>Services:</strong> {c.service}</div>
						<div><strong>Fleet:</strong> Toyota Alphard / Vellfire MPV fleet</div>
						<div><strong>Edge:</strong> Cross-border HKZM Bridge expertise, trilingual chauffeurs (EN, PT, CN)</div>
					</div>
				</div>
			</div>
		</section>

		<!-- Where Your Money Goes + Conversions -->
		<section class="section">
			<div class="wrapper">
				<h2><span class="section-icon">💰</span> Where Your Ad Budget Is Going</h2>

				<div class="chart-two-col">
					<div>
						<h3 style="margin-top:0">Roughly 92% is reaching the wrong audience</h3>
						<p>Your ads show up when someone searches for ferries, buses, and tour packages — not executive cars. These people want cheap public transport, not a premium chauffeur.</p>
						<div class="bar-chart">
							<div class="bar-row">
								<span class="bar-label">Wasted spend</span>
								<div class="bar-track"><div class="bar-fill b--red" style={"width:" + wastePct + "%"}><span class="bar-fill-text">~{wastePct}%</span></div></div>
								<span class="bar-right">~{r.ccy} {Math.round(wasteTotal)}/mo</span>
							</div>
							<div class="bar-row">
								<span class="bar-label">Potentially productive</span>
								<div class="bar-track"><div class="bar-fill b--green" style={"width:" + productivePct + "%"}}><span class="bar-fill-text">{productivePct}%</span></div></div>
								<span class="bar-right">~{r.ccy} {Math.round(r.spend/4.3 - wasteTotal)}/mo</span>
							</div>
						</div>
					</div>
					<div class="pie-wrap">
						<svg class="pie-svg" viewBox="0 0 200 200">
							<circle cx="100" cy="100" r="90" fill="none" stroke="#e2e8f0" stroke-width="20" />
							<circle cx="100" cy="100" r="90" fill="none" stroke="#ef4444" stroke-width="20" stroke-dasharray={wastePct * 5.65 + " " + (565 - wastePct * 5.65)} stroke-dashoffset="141.4" />
							<circle cx="100" cy="100" r="90" fill="none" stroke="#10b981" stroke-width="20" stroke-dasharray={productivePct * 5.65 + " " + (565 - productivePct * 5.65)} stroke-dashoffset={141.4 + wastePct * 5.65} />
						</svg>
					</div>
				</div>

				<div class="alert alert-warn">
					<strong>That's ~{r.ccy} {Math.round(wasteTotal)}/month</strong> going to clicks from people looking for ferries, buses, and budget travel. Fixing this alone saves over {r.ccy} 4,000/year.
				</div>

				<!-- Conversions result right here next to budget -->
				<div class="alert alert-critical" style="margin-top:20px">
					<strong>272 clicks, zero tracked bookings.</strong> For a chauffeur service where most bookings happen by phone or WhatsApp, we can't tell if anyone actually called or booked after seeing your ad. This needs to be fixed before we can optimize anything.
				</div>
				<ul class="findings-list">
					<li><strong>No booking tracking</strong> — we don't know if anyone submitted a form or called after clicking</li>
					<li><strong>No call tracking</strong> — essential for a phone-booking business like yours</li>
					<li><strong>No WhatsApp tracking</strong> — your customers reach you on WhatsApp, but ads can't see it</li>
				</ul>
			</div>
		</section>

		<!-- Account -->
		<section class="section">
			<div class="wrapper">
				<h2><span class="section-icon">📊</span> Your Campaigns at a Glance</h2>
				<table class="data-table">
					<thead><tr><th>Campaign</th><th>Type</th><th>Status</th><th>Weekly Spend</th><th>Clicks</th><th>Bookings</th></tr></thead>
					<tbody>
						<tr class="row-danger">
							<td>Search Transpolink Page<br /><small>(ChatGPT-built, wrong audience)</small></td>
							<td>Search</td>
							<td><span class="badge badge-enabled">Running</span></td>
							<td>{r.ccy} 1,174</td><td>272</td><td><strong>0</strong></td>
						</tr>
						<tr class="row-paused">
							<td>WEBSITE KEYWORDS MACAU AND HK<br /><small>(Better structure — paused)</small></td>
							<td>Search</td>
							<td><span class="badge badge-paused">Paused</span></td>
							<td>{r.ccy} 0</td><td>0</td><td>0</td>
						</tr>
					</tbody>
				</table>

				<h3>What People Are Clicking (Last 30 Days)</h3>
				<p>These are the actual searches your ad budget paid for. The red ones are people looking for public transport — not limousines.</p>
				<div class="bar-chart">
					{searchTerms.map(t => (
						<div class="bar-row">
							<span class="bar-label" style="font-size:0.78rem">{t.term}</span>
							<div class="bar-track"><div class={"bar-fill " + (t.verdict === 'bad' ? 'b--red' : 'b--green')} style={"width:" + (t.spend / maxSearchTermSpend * 100).toFixed(0) + "%"}}><span class="bar-fill-text">{r.ccy} {t.spend.toFixed(0)}</span></div></div>
							<span class="bar-right" style="font-size:0.8rem">{t.clicks} clicks</span>
						</div>
					))}
				</div>

				<h3>Keywords You Should Target Instead</h3>
				<p>These are the terms your ideal customers actually search for. None of them are in your campaign. We checked Google Trends to see which keywords have real search volume:</p>
				<div style="margin:16px 0">
					<div class="bar-chart">
						<div class="bar-row">
							<span class="bar-label" style="font-size:0.78rem">macau airport transfer</span>
							<div class="bar-track"><div class="bar-fill b--blue" style="width:100%"><span class="bar-fill-text">Highest volume</span></div></div>
							<span class="bar-right" style="font-size:0.8rem">Strong 🔥</span>
						</div>
						<div class="bar-row">
							<span class="bar-label" style="font-size:0.78rem">private car macau</span>
							<div class="bar-track"><div class="bar-fill b--blue" style="width:52%"><span class="bar-fill-text">Medium volume</span></div></div>
							<span class="bar-right" style="font-size:0.8rem">Good</span>
						</div>
						<div class="bar-row">
							<span class="bar-label" style="font-size:0.78rem">chauffeur service macau</span>
							<div class="bar-track"><div class="bar-fill b--blue" style="width:7%"><span class="bar-fill-text">Lower volume</span></div></div>
							<span class="bar-right" style="font-size:0.8rem">Niche</span>
						</div>
						<div class="bar-row">
							<span class="bar-label" style="font-size:0.78rem">hong kong to macau limo</span>
							<div class="bar-track"><div class="bar-fill b--gray" style="width:0%"><span class="bar-fill-text">Very low</span></div></div>
							<span class="bar-right" style="font-size:0.8rem">Test first</span>
						</div>
						<div class="bar-row">
							<span class="bar-label" style="font-size:0.78rem">cross border car macau</span>
							<div class="bar-track"><div class="bar-fill b--gray" style="width:0%"><span class="bar-fill-text">Very low</span></div></div>
							<span class="bar-right" style="font-size:0.8rem">Test first</span>
						</div>
					</div>
				</div>

				<!-- NEW: What Your Campaign Should Look Like -->
				<h3 style="margin-top:48px">What Your Campaign Should Look Like</h3>
				<p>Based on standard best practices for a premium chauffeur service in the GBA, here's the setup we recommend — built to reach people who book cars, not people who book ferries.</p>

				<div class="campaign-blueprint">
					<div class="bp-section">
						<h4>📐 Campaign Structure</h4>
						<table class="data-table">
							<thead><tr><th>Campaign</th><th>Ad Group</th><th>Sample Keywords</th><th>Match Type</th></tr></thead>
							<tbody>
								<tr>
									<td rowspan="3" style="border-right:1px solid var(--border)"><strong>Non-Brand Search</strong><br /><small>Main campaign for new customer acquisition</small></td>
									<td>Airport Transfers</td>
									<td><code>macau airport transfer</code>, <code>private car macau airport</code></td>
									<td>Exact + Phrase</td>
								</tr>
								<tr>
									<td>Cross-Border Travel</td>
									<td><code>hong kong to macau car</code>, <code>cross border car macau</code></td>
									<td>Exact + Phrase</td>
								</tr>
								<tr>
									<td>Chauffeur Hire</td>
									<td><code>chauffeur service macau</code>, <code>private driver macau</code></td>
									<td>Exact + Phrase</td>
								</tr>
								<tr>
									<td><strong>Brand Search</strong><br /><small>Protect your name</small></td>
									<td>Brand Terms</td>
									<td><code>transpolink</code>, <code>transpolink limo</code></td>
									<td>Exact</td>
								</tr>
							</tbody>
						</table>
					</div>

					<div class="bp-section">
						<h4>⚙️ Settings</h4>
						<div class="settings-grid">
							<div class="setting-card">
								<span class="setting-label">Network</span>
								<span class="setting-val">Search only<br /><small>No Display Network. No Search Partners (they drain budget).</small></span>
							</div>
							<div class="setting-card">
								<span class="setting-label">Location</span>
								<span class="setting-val">Macau + Hong Kong<br /><small>"Presence" mode only — not "Presence or Interest".</small></span>
							</div>
							<div class="setting-card">
								<span class="setting-label">Bidding</span>
								<span class="setting-val">Maximize Conversions<br /><small>Start here (zero conversion data). Switch to Target CPA once you get 30+ bookings/month.</small></span>
							</div>
							<div class="setting-card">
								<span class="setting-label">Ad Schedule</span>
								<span class="setting-val">8 AM – 10 PM daily<br /><small>Aligns with when business travellers book cars.</small></span>
							</div>
							<div class="setting-card">
								<span class="setting-label">Ad Rotation</span>
								<span class="setting-val">Optimize<br /><small>Let Google show the best-performing headlines.</small></span>
							</div>
							<div class="setting-card">
								<span class="setting-label">Device</span>
								<span class="setting-val">Mobile bid +20%<br /><small>~70% of searches happen on phones — business travellers on the go.</small></span>
							</div>
						</div>
					</div>

					<div class="bp-section">
						<h4>📝 Your Ads (RSAs)</h4>
						<p>Each ad group gets its own Responsive Search Ad with these three headline types pinned:</p>
						<div class="ad-example">
							<div class="ad-headline">🚗 <strong>Premium Chauffeur, Macau Airport</strong></div>
							<div class="ad-headline">⭐ <strong>Toyota Alphard with 5G Wi-Fi</strong></div>
							<div class="ad-headline">📞 <strong>Book Your Private Transfer Today</strong></div>
							<div class="ad-desc">Executive MPV fleet with trilingual chauffeurs. Cross-border HKZM Bridge specialist. Fixed pricing, no surge. Book via WhatsApp or call now.</div>
						</div>
						<p style="margin-top:12px"><strong>Ad assets (extensions) to add:</strong> Call button (essential for phone bookings), Sitelinks (Airport Transfers, Chauffeur Hire, Contact), Location asset (linked to Google Business Profile), Callouts ("Trilingual Chauffeurs", "Fixed Pricing", "HKZM Bridge Expert", "5G Wi-Fi").</p>
					</div>

					<div class="bp-section">
						<h4>🔑 Daily Budget</h4>
						<p>Start at <strong>{r.ccy} 200/day</strong> (~{r.ccy} 6,000/month — slightly above current spend). This is enough for 5–8 clicks per day on high-intent keywords at current CPC levels. Once tracking shows which keywords actually convert, we can scale the winners and reduce on the rest.</p>
					</div>

					<div class="bp-section">
						<h4>🚀 Prerequisites Before Launch</h4>
						<p>Three things must be in place before turning on the new campaign:</p>
						<ol class="findings-list" style="list-style:decimal;padding-left:20px">
							<li><strong>Call tracking installed</strong> — every phone call from an ad gets logged as a conversion</li>
							<li><strong>WhatsApp click tracking</strong> — so we know when someone messages you from the ad</li>
							<li><strong>Dedicated landing pages</strong> — one page per service (Airport, Cross-Border, Chauffeur Hire) instead of sending everyone to the homepage</li>
						</ol>
					</div>

					<div class="bp-section">
						<h4>📈 After 30 Days (When We Have Data)</h4>
						<p>Once the campaign collects 30–50+ bookings per month:</p>
						<ul class="findings-list">
							<li>Switch bidding to <strong>Target CPA</strong> at {r.ccy} 100–150 per booking (Google AI optimizes automatically)</li>
							<li><strong>Expand keywords</strong> from search terms report — add converting terms as exact match</li>
							<li><strong>Launch Performance Max</strong> campaign to show video ads on YouTube targeting business travellers planning GBA trips</li>
							<li>Set up <strong>retargeting</strong> for people who visited the booking page but didn't complete a reservation</li>
						</ul>
					</div>
				</div>
			</div>
		</section>

		<!-- Search Console -->
		<section class="section">
			<div class="wrapper">
				<h2><span class="section-icon">🔍</span> Your Free Traffic (Google Search)</h2>
				<div class="kpi-row">
					<div class="kpi-item"><span class="kpi-num">87</span><span class="kpi-label">Free clicks (90 days)</span></div>
					<div class="kpi-item"><span class="kpi-num">2,986</span><span class="kpi-label">Times shown in search</span></div>
					<div class="kpi-item"><span class="kpi-num">2.9%</span><span class="kpi-label">Click-through rate</span></div>
					<div class="kpi-item"><span class="kpi-num">5.2</span><span class="kpi-label">Average ranking position</span></div>
				</div>
				<p>You rank #1 for "limo service macau" and "macau limousine service" — strong positions. But your website has <strong>24 pages that Google knows about and zero that it's actually showing in search results.</strong></p>
				<div class="alert alert-high"><strong>Quick fix:</strong> Adding proper business schema (LocalBusiness markup) and fixing internal links can help Google index your pages and drive more free traffic.</div>
			</div>
		</section>

		<!-- Website -->
		<section class="section">
			<div class="wrapper">
				<h2><span class="section-icon">🖥️</span> Website Check</h2>
				<ul class="findings-list">
					<li><strong>Look and feel:</strong> Clean, professional. Good first impression.</li>
					<li><strong>Mobile-friendly:</strong> Yes — important since ~70% of your traffic is on phones.</li>
					<li><strong>Booking page:</strong> Only got 2 free clicks in 90 days. The form might be hard to find or too long.</li>
					<li><strong>Call tracking:</strong> Not detected — for a business where customers call to book, this is a big gap.</li>
					<li><strong>Ad vs page:</strong> Your ads promise one thing, but the page they land on doesn't match. This hurts your Quality Score and raises your costs.</li>
				</ul>
			</div>
		</section>

		<!-- Recommendations -->
		<section class="section">
			<div class="wrapper">
				<h2><span class="section-icon">🎯</span> What We Recommend</h2>
				<p>Listed in order of impact. Start from the top and work down.</p>

				<div class="rec-list">
					<div class="rec-item">
						<h4>Set up tracking so we can measure results</h4>
						<p>Install call tracking, WhatsApp click tracking, and a booking form tracker. Without this, we're flying blind. Once installed, we'll know exactly which ads are working.</p>
					</div>
					<div class="rec-item">
						<h4>Stop paying for ferry and bus searches</h4>
						<p>Add roughly 20 negative keywords (ferry, bus, tour, schedule, fare, ticket, cheap, free, how to) at the account level. This is a 15-minute fix that saves ~{r.ccy} 350-450/month immediately.</p>
					</div>
					<div class="rec-item">
						<h4>Rebuild the campaign to target the right people</h4>
						<p>Pause the current campaign (it's targeting the wrong audience). Reactivate the paused "MACAU AND HK" campaign or start fresh. Create ad groups for: Airport Transfers, Cross-Border Travel, Chauffeur Hire, and Brand Terms. Use exact-match keywords for the high-intent terms listed above.</p>
					</div>
					<div class="rec-item">
						<h4>Fix your website's search visibility</h4>
						<p>Add LocalBusiness structured data (schema markup) to your site. Check why Google hasn't indexed any of your 24 pages. Submit key pages manually via Search Console. This will help more people find you for free.</p>
					</div>
					<div class="rec-item">
						<h4>Create dedicated landing pages for each service</h4>
						<p>Instead of sending all ad traffic to your homepage, build separate pages for Airport Transfers, Cross-Border, and Chauffeur Hire. Each ad should point to a page that matches exactly what it promises.</p>
					</div>
					<div class="rec-item">
						<h4>Set up retargeting for website visitors</h4>
						<p>Once tracking is working, create a campaign that shows your ads to people who visited your booking page but didn't complete a reservation. This catches people who were interested but got distracted.</p>
					</div>
					<div class="rec-item">
						<h4>Expand to Performance Max once stable</h4>
						<p>After you're getting 50+ bookings per month, launch a Performance Max campaign to show ads across YouTube, Display networks, and Gmail — reaching potential clients who aren't actively searching yet.</p>
					</div>
				</div>
			</div>
		</section>

		<!-- Projected Impact -->
		<section class="section">
			<div class="wrapper">
				<h2><span class="section-icon">📈</span> What We Expect to Achieve</h2>
				<p>These estimates are based on fixing the issues found in this audit. Results will vary, but here's what similar campaigns achieve after restructuring:</p>
				<div class="impact-grid">
					<div class="impact-card">
						<h4>Immediate savings</h4>
						<p class="impact-num">{r.ccy} 4,200<small>/year</small></p>
						<p class="impact-desc">From stopping waste on ferry, bus, and tour keywords alone. This is money you're spending today that generates zero leads.</p>
					</div>
					<div class="impact-card">
						<h4>Cost per booking</h4>
						<p class="impact-num">{r.ccy} 80–150</p>
						<p class="impact-desc">Expected cost per qualified lead once we target the right keywords. At {r.ccy} 5,020/month, that's 33–62 potential bookings per month.</p>
					</div>
					<div class="impact-card">
						<h4>From zero to measurable</h4>
						<p class="impact-num">15–30<small>/month</small></p>
						<p class="impact-desc">Realistic first-month bookings after campaign restructure and tracking setup. Scales as we optimize and add more high-intent keywords.</p>
					</div>
					<div class="impact-card">
						<h4>Free search traffic</h4>
						<p class="impact-num">3–5x</p>
						<p class="impact-desc">Expected organic traffic increase from fixing sitemap indexing and adding schema markup. More free visibility for your brand.</p>
					</div>
				</div>
			</div>
		</section>
	</section>

</AuditLayout>

<style is:global>
	/* Campaign Blueprint */
	.campaign-blueprint { margin: 24px 0; display: flex; flex-direction: column; gap: 28px; }
	.bp-section { background: var(--bg-subtle, #f6f8fc); border-radius: var(--radius-md, 12px); padding: 24px; border: 1px solid var(--border, rgba(15,23,42,0.1)); }
	.bp-section h4 { margin: 0 0 16px; font-size: 1rem; font-weight: 700; color: var(--text, #0f172a); }
	.bp-section p { margin: 0 0 12px; font-size: 0.9rem; color: var(--text-muted, #525866); }
	.bp-section p:last-child { margin-bottom: 0; }
	.bp-section .data-table { margin: 0 0 8px; }
	.bp-section .findings-list { margin: 8px 0 0; }

	/* Settings grid */
	.settings-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; }
	.setting-card { background: #fff; border-radius: 8px; padding: 14px 16px; border: 1px solid var(--border); }
