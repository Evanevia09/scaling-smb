---
import BaseLayout from '../layouts/BaseLayout.astro';
import JsonLd from '../components/seo/JsonLd.astro';
import Header from '../components/Header.astro';
import Hero from '../components/landing/Hero.astro';
import Services from '../components/landing/Services.astro';
import HowItWorks from '../components/landing/HowItWorks.astro';
import Projects from '../components/landing/Projects.astro';
import CtaBand from '../components/landing/CtaBand.astro';
import Contact from '../components/landing/Contact.astro';
import Footer from '../components/landing/Footer.astro';
import WhatsAppFab from '../components/WhatsAppFab.astro';
import { seo } from '../content/site';
import {
	organizationJsonLd,
	professionalServiceJsonLd,
	webSiteJsonLd,
} from '../lib/seo';
---

<BaseLayout title={seo.title} description={seo.description} ogImage={seo.defaultOgImage}>
	<JsonLd
		data={[organizationJsonLd(Astro.site), webSiteJsonLd(Astro.site), professionalServiceJsonLd(Astro.site)]}
	/>
	<Header />
	<main id="main" class="landing">
		<Hero />
		<Services />
		<HowItWorks />
		<CtaBand />
		<Projects />
		<Contact />
	</main>
	<Footer />
	<WhatsAppFab />
</BaseLayout>
