---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import WhatsAppFab from "../components/WhatsAppFab.astro";
---

<Layout title="Thank You · Scaling SMB" description="Your enquiry has been received. We'll get back to you within 24 hours.">
  <Header />
  <main class="min-h-[80vh] flex items-center justify-center pt-24 pb-16">
    <div class="mx-auto max-w-2xl px-4 sm:px-6 lg:px-8 text-center" data-reveal>
      <!-- Success checkmark -->
      <div class="mx-auto mb-8 flex h-20 w-20 items-center justify-center rounded-full bg-green-100 text-green-600">
        <svg width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
          <polyline points="20 6 9 17 4 12"/>
        </svg>
      </div>

      <!-- Dynamic greeting -->
      <h1 class="text-4xl sm:text-5xl font-black tracking-tight mb-4" id="greeting">
        Thank You!
      </h1>
      <p class="text-xl text-muted mb-3" id="personal-greeting">
        Your enquiry has been received.
      </p>
      <p class="text-muted leading-relaxed mb-8 max-w-md mx-auto">
        We've got your message and will review it shortly. One of our team members will reach out to you within 24 hours.
      </p>

      <!-- What happens next -->
      <div class="grid gap-4 sm:grid-cols-3 text-left mb-12">
        <div class="rounded-xl border border-border bg-surface/50 p-5 text-center">
          <div class="mx-auto mb-3 flex h-10 w-10 items-center justify-center rounded-lg bg-primary-light text-primary">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/>
            </svg>
          </div>
          <h4 class="font-bold text-sm mb-1">We Review</h4>
          <p class="text-xs text-muted">Our team reviews your project details</p>
        </div>
        <div class="rounded-xl border border-border bg-surface/50 p-5 text-center">
          <div class="mx-auto mb-3 flex h-10 w-10 items-center justify-center rounded-lg bg-primary-light text-primary">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
              <polyline points="22,6 12,13 2,6"/>
            </svg>
          </div>
          <h4 class="font-bold text-sm mb-1">We Reach Out</h4>
          <p class="text-xs text-muted">We contact you within 24 hours</p>
        </div>
        <div class="rounded-xl border border-border bg-surface/50 p-5 text-center">
          <div class="mx-auto mb-3 flex h-10 w-10 items-center justify-center rounded-lg bg-primary-light text-primary">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <polyline points="16 18 22 12 16 6"/>
              <polyline points="8 6 2 12 8 18"/>
            </svg>
          </div>
          <h4 class="font-bold text-sm mb-1">We Build</h4>
          <p class="text-xs text-muted">We craft the perfect solution for you</p>
        </div>
      </div>

      <!-- Back home -->
      <a href="/" class="inline-flex items-center gap-2 rounded-xl bg-primary px-8 py-4 text-base font-semibold text-white transition-all hover:bg-primary-dark active:scale-[0.97] shadow-lg shadow-primary/25">
        <svg width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M12 8H4"/>
          <path d="M8 4L4 8L8 12"/>
        </svg>
        Back to Home
      </a>
    </div>
  </main>
  <Footer />
  <WhatsAppFab />
</Layout>

<script>
  // Read the name from sessionStorage and personalize the message
  const name = sessionStorage.getItem('thankYouName');
  if (name) {
    document.getElementById('greeting').textContent = `Thank You, ${name}!`;
    document.getElementById('personal-greeting').textContent = `Your enquiry has been received, ${name}.`;
    // Clean up
    sessionStorage.removeItem('thankYouName');
  }
</script>
