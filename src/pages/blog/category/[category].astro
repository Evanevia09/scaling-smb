---
import BlogLayout from '../../../layouts/BlogLayout.astro';
import JsonLd from '../../../components/seo/JsonLd.astro';
import BlogPostList from '../../../components/blog/BlogPostList.astro';
import {
	filterByCategory,
	getCategories,
	getPublishedPosts,
	slugifyCategory,
} from '../../../lib/blog';
import { blogIndex } from '../../../content/site';
import { breadcrumbJsonLd, collectionPageJsonLd } from '../../../lib/seo';

export async function getStaticPaths() {
	const posts = await getPublishedPosts();
	const categories = getCategories(posts);
	return categories.map((category) => ({
		params: { category: slugifyCategory(category) },
		props: { category },
	}));
}

const { category } = Astro.props;
const posts = await getPublishedPosts();
const filtered = filterByCategory(posts, Astro.params.category!);
const title = `${category} | Blog | Scaling SMB`;
const description = `Articles about ${category} for local small and medium businesses. ${blogIndex.lede}`;
const categoryPath = `/blog/category/${Astro.params.category}/`;
---

<BlogLayout title={title} description={description} posts={posts} activeCategory={category}>
	<JsonLd
		data={[
			collectionPageJsonLd({ name: title, description, path: categoryPath }, Astro.site),
			breadcrumbJsonLd(
				[
					{ name: 'Home', path: '/' },
					{ name: 'Blog', path: '/blog/' },
					{ name: category, path: categoryPath },
				],
				Astro.site,
			),
		]}
	/>
	<header class="blog-category-head">
		<p class="blog-category-head__back">
			<a href="/blog/">← All posts</a>
		</p>
		<p class="eyebrow">Category</p>
		<h1 class="blog-category-head__title">{category}</h1>
		<p class="blog-index-head__lede">
			{filtered.length} {filtered.length === 1 ? 'article' : 'articles'} on {category.toLowerCase()}.
		</p>
	</header>

	{
		filtered.length === 0 ? (
			<p class="blog-empty">No posts in this category yet.</p>
		) : (
			<BlogPostList posts={filtered} />
		)
	}
</BlogLayout>
