---
// About section
---

<section id="about" class="py-16 sm:py-20 lg:py-32 bg-surface/50">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="grid gap-12 lg:grid-cols-2 lg:gap-16 items-center">
      <!-- Copy -->
      <div data-reveal>
        <p class="text-sm font-semibold text-primary tracking-widest uppercase mb-4">About Us</p>
        <h2 class="text-4xl sm:text-5xl font-black tracking-tight mb-6">
          Your <span class="text-primary">Digital Partner</span> in Macau & APAC
        </h2>
        <p class="text-lg text-muted leading-relaxed mb-6">
          Scaling SMB helps small and mid-sized businesses launch modern websites, apps, and growth systems — 
          without bloated timelines or agency overhead.
        </p>
        <p class="text-muted leading-relaxed mb-8">
          We are a lean team of designers and developers based in Macau, working with clients across Hong Kong, 
          Singapore, and beyond. You get direct access to the people building your product, not a rotating cast 
          of account managers.
        </p>
        <a
          href="#contact"
          class="inline-flex items-center gap-2 rounded-xl bg-primary px-6 py-3 text-sm font-semibold text-white transition-all hover:bg-primary-dark active:scale-[0.97] shadow-lg shadow-primary/25"
        >
          Start a Conversation
          <svg width="14" height="14" viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M5 11L9 7L5 3"/>
          </svg>
        </a>
      </div>

      <!-- Values + Stats -->
      <div class="space-y-8" data-reveal data-delay="100">
        <!-- Values -->
        <div class="grid gap-4 sm:grid-cols-3">
          <div class="rounded-2xl border border-border bg-white p-5 sm:p-6 transition-all hover:border-primary/20 hover:shadow-md">
            <div class="mb-3 flex h-10 w-10 items-center justify-center rounded-lg bg-primary-light text-primary">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                <polyline points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/>
              </svg>
            </div>
            <h3 class="font-bold mb-1">Ship Fast</h3>
            <p class="text-sm text-muted">Focused sprints so you launch weeks sooner, not months later.</p>
          </div>
          <div class="rounded-2xl border border-border bg-white p-5 sm:p-6 transition-all hover:border-primary/20 hover:shadow-md">
            <div class="mb-3 flex h-10 w-10 items-center justify-center rounded-lg bg-primary-light text-primary">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
              </svg>
            </div>
            <h3 class="font-bold mb-1">Built for SMBs</h3>
            <p class="text-sm text-muted">Right-sized scope and pricing — no enterprise fluff.</p>
          </div>
          <div class="rounded-2xl border border-border bg-white p-5 sm:p-6 transition-all hover:border-primary/20 hover:shadow-md">
            <div class="mb-3 flex h-10 w-10 items-center justify-center rounded-lg bg-primary-light text-primary">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/>
                <path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/>
              </svg>
            </div>
            <h3 class="font-bold mb-1">APAC-Ready</h3>
            <p class="text-sm text-muted">Local SEO, WeChat, and regional UX baked in from day one.</p>
          </div>
        </div>

        <!-- Stats -->
        <div class="grid grid-cols-3 gap-4 rounded-2xl border border-border bg-white p-6">
          <div class="text-center">
            <div class="text-3xl font-black text-primary">50+</div>
            <div class="text-xs text-muted mt-1">Projects Delivered</div>
          </div>
          <div class="text-center border-x border-border">
            <div class="text-3xl font-black text-primary">8+</div>
            <div class="text-xs text-muted mt-1">Years Experience</div>
          </div>
          <div class="text-center">
            <div class="text-3xl font-black text-primary">APAC</div>
            <div class="text-xs text-muted mt-1">Regional Focus</div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
