---
---

<section class="relative min-h-screen flex items-center overflow-hidden pt-28 pb-20">
  <div class="absolute inset-0 pointer-events-none overflow-hidden">
    <div class="absolute -top-40 -right-40 w-[500px] h-[500px] bg-primary/[0.03] rounded-full blur-3xl" />
    <div class="absolute -bottom-40 -left-40 w-[400px] h-[400px] bg-primary/[0.02] rounded-full blur-3xl" />
  </div>

  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 relative z-10">
    <div class="mx-auto max-w-4xl text-center">
      <h1 class="text-4xl sm:text-5xl md:text-6xl lg:text-7xl font-light tracking-tight leading-[1.05] sm:leading-[0.95] mb-6 sm:mb-8 text-heading">
        Hire a dedicated <br class="hidden sm:block" />
        <span class="relative inline-block font-medium">
          AI employee
          <span class="absolute -bottom-2 left-0 right-0 h-3 bg-primary/10 -z-10 rounded-full" />
        </span>
        <br class="hidden sm:block" />
        built for your business.
      </h1>

      <p class="mx-auto max-w-2xl text-base sm:text-lg text-body leading-relaxed mb-10">
        Pick the department that needs support. During a free discovery call, we'll map out 
        exactly which tasks your AI Employee should handle — everything is customized to your business.
      </p>

      <div class="flex flex-col sm:flex-row items-center justify-center gap-4 mb-16">
        <a
          href="#roles"
          class="inline-flex items-center gap-2 rounded-lg bg-primary px-7 py-3.5 text-sm font-semibold text-white transition-all hover:bg-primary-dark active:scale-[0.97] shadow-xl shadow-primary/25 hover:shadow-2xl hover:shadow-primary/30"
        >
          See available roles
          <svg width="14" height="14" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M6 12L10 8L6 4"/>
          </svg>
        </a>
        <a
          href="#contact"
          class="inline-flex items-center gap-2 rounded-lg border border-primary/20 bg-primary-light px-7 py-3.5 text-sm font-semibold text-primary transition-all hover:bg-primary/10 active:scale-[0.97]"
        >
          Book a discovery call
        </a>
      </div>
    </div>

    <!-- Quick stats -->
    <div class="mx-auto max-w-3xl">
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-6 rounded-2xl border border-border bg-white/80 backdrop-blur-sm p-8 shadow-sm">
        <div class="text-center">
          <div class="text-sm font-semibold text-primary tracking-wide uppercase mb-1">Departments</div>
          <div class="text-2xl font-bold text-heading">Operations · Marketing · Sales</div>
        </div>
        <div class="text-center border-t sm:border-t-0 sm:border-l border-border pt-4 sm:pt-0 sm:pl-6">
          <div class="text-sm font-semibold text-primary tracking-wide uppercase mb-1">Customization</div>
          <div class="text-2xl font-bold text-heading">Tailored to your business</div>
        </div>
      </div>
    </div>
  </div>
</section>
