---
// Hero section
const stats = [
  { label: "Projects Delivered", value: "50+" },
  { label: "Years Experience", value: "8+" },
  { label: "Client Retention", value: "95%" },
];
---

<section id="home" class="relative min-h-screen flex items-center overflow-hidden pt-24 pb-16">
  <!-- Background decoration -->
  <div class="absolute inset-0 pointer-events-none overflow-hidden">
    <div class="absolute -top-40 -right-40 w-96 h-96 bg-primary/5 rounded-full blur-3xl" />
    <div class="absolute -bottom-40 -left-40 w-80 h-80 bg-primary/3 rounded-full blur-3xl" />
    <div class="absolute top-1/3 left-1/4 w-2 h-2 bg-primary/30 rounded-full animate-pulse" style="animation-duration: 3s" />
    <div class="absolute top-1/4 right-1/3 w-1.5 h-1.5 bg-primary/20 rounded-full animate-pulse" style="animation-duration: 4s; animation-delay: 1s" />
    <div class="absolute bottom-1/3 right-1/4 w-1 h-1 bg-primary/25 rounded-full animate-pulse" style="animation-duration: 3.5s; animation-delay: 0.5s" />
  </div>

  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 relative z-10">
    <div class="mx-auto max-w-4xl text-center" data-reveal>
      <!-- Badge -->
      <div class="mb-8 inline-flex items-center gap-2 rounded-full border border-primary/20 bg-primary-light px-4 py-1.5 text-xs font-semibold tracking-wide text-primary">
        <span class="inline-block h-2 w-2 rounded-full bg-primary animate-pulse" />
        Web Development & Growth Systems
      </div>

      <!-- Headline -->
      <h1 class="text-5xl sm:text-6xl lg:text-7xl xl:text-8xl font-black tracking-tight leading-[0.95] mb-8" data-reveal data-delay="100">
        Custom Websites That
        <span class="relative inline-block">
          <span class="text-primary">Scale</span>
          <span class="absolute -bottom-2 left-0 right-0 h-3 bg-primary/10 -z-10 rounded-full" />
        </span>
        Your Business
      </h1>

      <!-- Subtitle -->
      <p class="mx-auto max-w-2xl text-lg sm:text-xl text-muted leading-relaxed mb-10" data-reveal data-delay="200">
        We build fast, modern, and scalable websites that turn visitors into customers. 
        Based in <strong class="text-dark">Macau</strong>, serving businesses across <strong class="text-dark">APAC</strong>.
      </p>

      <!-- CTAs -->
      <div class="flex flex-col sm:flex-row items-center justify-center gap-4 mb-16" data-reveal data-delay="300">
        <a
          href="#contact"
          class="inline-flex items-center gap-2 rounded-xl bg-primary px-8 py-4 text-base font-semibold text-white transition-all hover:bg-primary-dark active:scale-[0.97] shadow-xl shadow-primary/25 hover:shadow-2xl hover:shadow-primary/30"
        >
          Start Your Project
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M6 12L10 8L6 4"/>
          </svg>
        </a>
        <a
          href="#portfolio"
          class="inline-flex items-center gap-2 rounded-xl border-2 border-border bg-white px-8 py-4 text-base font-semibold text-dark transition-all hover:border-primary/30 hover:bg-primary-light active:scale-[0.97]"
        >
          View Our Work
        </a>
      </div>
    </div>

    <!-- Stats bar -->
    <div class="mx-auto max-w-2xl" data-reveal data-delay="400">
      <div class="grid grid-cols-3 gap-8 rounded-2xl border border-border bg-white/80 backdrop-blur-sm p-8 shadow-sm">
        {stats.map((stat) => (
          <div class="text-center">
            <div class="text-3xl font-black text-primary">{stat.value}</div>
            <div class="mt-1 text-sm text-muted">{stat.label}</div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

<script>
  // Intersection Observer for reveal animations
  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          const delay = parseInt(entry.target.dataset.delay) || 0;
          setTimeout(() => {
            entry.target.classList.add(
              'opacity-100', 'translate-y-0'
            );
          }, delay);
        }
      });
    },
    { threshold: 0.1 }
  );

  document.querySelectorAll('[data-reveal]').forEach((el) => {
    el.classList.add('opacity-0', 'translate-y-8', 'transition-all', 'duration-700', 'ease-out');
    observer.observe(el);
  });
</script>
