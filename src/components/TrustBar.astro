---
// Trust / Client Logo Bar
const brands = ["NORTHWIND", "BRIGHTFLOW", "CORNERSTONE", "SNAPSHOT", "VISIONARY", "ATLASCORE"];
---

<section class="py-16 border-y border-border bg-surface/50">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <p class="text-center text-sm font-medium text-muted mb-10 tracking-wide uppercase">
      Trusted by growing businesses
    </p>
    <div class="grid grid-cols-2 gap-8 sm:grid-cols-3 md:grid-cols-6 items-center justify-items-center">
      {brands.map((brand) => (
        <div class="flex items-center gap-2 text-dark/30 group transition-all duration-300 hover:text-dark/50">
          <span class="text-sm font-bold tracking-[0.15em] uppercase">{brand}</span>
        </div>
      ))}
    </div>
  </div>
</section>
