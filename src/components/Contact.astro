---
---

<section id="contact" class="py-20 sm:py-28">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-2xl text-center mb-12">
      <p class="text-xs font-semibold text-primary tracking-widest uppercase mb-4">Get Started</p>
      <h2 class="text-3xl sm:text-4xl font-light tracking-tight text-heading mb-4">
        Ready to <span class="font-medium">hire your AI team?</span>
      </h2>
      <p class="text-body text-base leading-relaxed">
        Book a free discovery call. We'll identify the right roles for your business and get you set up.
      </p>
    </div>

    <div class="mx-auto max-w-lg">
      <form
        action="https://formspree.io/f/your-form-id"
        method="POST"
        class="space-y-5"
      >
        <div class="grid gap-5 sm:grid-cols-2">
          <div>
            <label for="name" class="block text-sm font-medium text-heading mb-1.5">Name</label>
            <input
              type="text"
              id="name"
              name="name"
              required
              class="w-full rounded-lg border border-border bg-white px-4 py-2.5 text-sm text-heading placeholder:text-muted focus:outline-none focus:ring-2 focus:ring-primary/30 focus:border-primary transition-all"
              placeholder="Your name"
            />
          </div>
          <div>
            <label for="email" class="block text-sm font-medium text-heading mb-1.5">Email</label>
            <input
              type="email"
              id="email"
              name="email"
              required
              class="w-full rounded-lg border border-border bg-white px-4 py-2.5 text-sm text-heading placeholder:text-muted focus:outline-none focus:ring-2 focus:ring-primary/30 focus:border-primary transition-all"
              placeholder="you@company.com"
            />
          </div>
        </div>
        <div>
          <label for="message" class="block text-sm font-medium text-heading mb-1.5">What roles interest you?</label>
          <textarea
            id="message"
            name="message"
            rows="3"
            class="w-full rounded-lg border border-border bg-white px-4 py-2.5 text-sm text-heading placeholder:text-muted focus:outline-none focus:ring-2 focus:ring-primary/30 focus:border-primary transition-all resize-none"
            placeholder="Tell us about your business and what you need..."
          ></textarea>
        </div>
        <button
          type="submit"
          class="w-full rounded-lg bg-primary px-6 py-3 text-sm font-semibold text-white transition-all hover:bg-primary-dark active:scale-[0.98] shadow-lg shadow-primary/25"
        >
          Book a discovery call
        </button>
      </form>

      <div class="mt-10 pt-8 border-t border-border text-center">
        <p class="text-xs text-body mb-3">Or reach us directly</p>
        <div class="flex items-center justify-center gap-6 text-sm">
          <a href="mailto:evan@scalingsmb.com" class="text-primary hover:text-primary-dark transition-colors font-medium">
            evan@scalingsmb.com
          </a>
          <span class="text-muted">·</span>
          <a href="tel:+85362750705" class="text-primary hover:text-primary-dark transition-colors font-medium">
            +853 6275 0705
          </a>
        </div>
      </div>
    </div>
  </div>
</section>
