---
const links = [
  { href: "#roles", label: "AI Employees" },
  { href: "#pricing", label: "Pricing" },
  { href: "#about", label: "About" },
];
---

<header class="fixed top-0 left-0 right-0 z-50 transition-all duration-300" id="site-header">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between py-4 md:py-5 transition-all duration-300">
      <a href="/" class="flex items-center gap-2 group shrink-0">
        <span class="text-xl font-bold text-heading tracking-tight">scalingsmb</span>
        <span class="hidden sm:inline text-xs font-medium text-primary/70 bg-primary-light px-2 py-0.5 rounded">AI</span>
      </a>

      <nav class="hidden md:flex items-center gap-8">
        {links.map((link) => (
          <a
            href={link.href}
            class="text-sm font-medium text-body hover:text-heading transition-colors"
          >
            {link.label}
          </a>
        ))}
        <a
          href="#contact"
          class="inline-flex items-center gap-1.5 rounded-lg bg-primary px-5 py-2.5 text-sm font-semibold text-white transition-all hover:bg-primary-dark active:scale-[0.97]"
        >
          Book a call
        </a>
      </nav>

      <button
        type="button"
        class="md:hidden relative z-50 p-3 -mr-2 text-heading touch-manipulation"
        aria-label="Toggle menu"
        data-menu-toggle
      >
        <span class="block h-0.5 w-6 bg-current transition-all duration-300" data-bar-1></span>
        <span class="block h-0.5 w-6 bg-current mt-1.5 transition-all duration-300" data-bar-2></span>
        <span class="block h-0.5 w-6 bg-current mt-1.5 transition-all duration-300" data-bar-3></span>
      </button>
    </div>
  </div>

  <div
    class="fixed inset-0 z-40 flex flex-col bg-white/95 backdrop-blur-xl md:hidden translate-x-full transition-transform duration-500 ease-out"
    data-mobile-menu
    aria-hidden="true"
  >
    <nav class="flex flex-1 flex-col items-center justify-center gap-8 px-8">
      {links.map((link, i) => (
        <a
          href={link.href}
          class="text-2xl font-semibold tracking-tight text-body/60 hover:text-heading transition-colors"
          data-menu-link
          style={`transition-delay: ${i * 50}ms`}
        >
          {link.label}
        </a>
      ))}
      <a
        href="#contact"
        class="mt-4 inline-flex items-center gap-2 rounded-xl bg-primary px-8 py-4 text-lg font-semibold text-white transition-all hover:bg-primary-dark"
        data-menu-link
      >
        Book a discovery call
      </a>
    </nav>
  </div>
</header>

<script>
  const header = document.getElementById('site-header');
  const toggle = document.querySelector('[data-menu-toggle]');
  const menu = document.querySelector('[data-mobile-menu]');
  const links = document.querySelectorAll('[data-menu-link]');
  const bars = {
    b1: document.querySelector('[data-bar-1]'),
    b2: document.querySelector('[data-bar-2]'),
    b3: document.querySelector('[data-bar-3]'),
  };

  let isOpen = false;

  function openMenu() {
    isOpen = true;
    menu.classList.remove('translate-x-full');
    toggle.setAttribute('aria-expanded', 'true');
    menu.setAttribute('aria-hidden', 'false');
    document.body.style.overflow = 'hidden';
    bars.b1.classList.add('rotate-45', 'translate-y-[7px]');
    bars.b2.classList.add('opacity-0');
    bars.b3.classList.add('-rotate-45', '-translate-y-[7px]');
  }

  function closeMenu() {
    isOpen = false;
    menu.classList.add('translate-x-full');
    toggle.setAttribute('aria-expanded', 'false');
    menu.setAttribute('aria-hidden', 'true');
    document.body.style.overflow = '';
    bars.b1.classList.remove('rotate-45', 'translate-y-[7px]');
    bars.b2.classList.remove('opacity-0');
    bars.b3.classList.remove('-rotate-45', '-translate-y-[7px]');
  }

  toggle.addEventListener('click', () => {
    isOpen ? closeMenu() : openMenu();
  });

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && isOpen) closeMenu();
  });

  menu.addEventListener('click', (e) => {
    if (e.target === menu) closeMenu();
  });

  links.forEach((link) => {
    link.addEventListener('click', () => closeMenu());
  });

  window.addEventListener('scroll', () => {
    const scrollY = window.scrollY;
    const nav = header.querySelector('div');
    if (scrollY > 50) {
      nav.classList.add('!py-3');
      header.classList.add('bg-white/90', 'backdrop-blur-xl', 'shadow-sm', 'border-b', 'border-border');
    } else {
      nav.classList.remove('!py-3');
      header.classList.remove('bg-white/90', 'backdrop-blur-xl', 'shadow-sm', 'border-b', 'border-border');
    }
  });
</script>
