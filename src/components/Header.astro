---
const links = [
  { href: "#roles", label: "AI Employees" },
  { href: "#about", label: "About" },
];
---

<header class="fixed top-0 left-0 right-0 z-50 bg-white backdrop-blur-md transition-all duration-300" id="site-header">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between py-3 md:py-4 transition-all duration-300">
      <a href="/" class="flex items-center gap-2 shrink-0">
        <span class="text-lg sm:text-xl font-bold text-heading tracking-tight">scalingsmb</span>
        <span class="text-[10px] sm:text-xs font-medium text-primary/70 bg-primary-light px-1.5 sm:px-2 py-0.5 rounded">AI</span>
      </a>

      <!-- Desktop nav -->
      <nav class="hidden md:flex items-center gap-8">
        {links.map((link) => (
          <a
            href={link.href}
            class="text-sm font-medium text-body hover:text-heading transition-colors"
          >
            {link.label}
          </a>
        ))}
        <a
          href="#contact"
          class="inline-flex items-center gap-1.5 rounded-lg bg-primary px-5 py-2.5 text-sm font-semibold text-white transition-all hover:bg-primary-dark active:scale-[0.97]"
        >
          Book a call
        </a>
      </nav>

      <!-- Mobile hamburger -->
      <button
        type="button"
        class="md:hidden relative z-50 p-2 -mr-2 text-heading touch-manipulation"
        aria-label="Toggle menu"
        aria-expanded="false"
        data-menu-toggle
      >
        <span class="block h-0.5 w-6 bg-current transition-all duration-300 origin-center" data-bar-1></span>
        <span class="block h-0.5 w-6 bg-current my-1.5 transition-all duration-300" data-bar-2></span>
        <span class="block h-0.5 w-6 bg-current transition-all duration-300 origin-center" data-bar-3></span>
      </button>
    </div>
  </div>

  <!-- Mobile dropdown menu -->
  <div
    class="md:hidden bg-white border-b border-border shadow-lg transition-all duration-300 overflow-hidden data-[open=false]:max-h-0 data-[open=false]:opacity-0 data-[open=true]:max-h-80 data-[open=true]:opacity-100"
    data-mobile-menu
    data-open="false"
    aria-hidden="true"
  >
    <nav class="px-4 sm:px-6 pb-5 pt-2 space-y-1">
      {links.map((link) => (
        <a
          href={link.href}
          class="block rounded-lg px-4 py-3 text-base font-medium text-body hover:text-heading hover:bg-surface transition-colors"
          data-menu-link
        >
          {link.label}
        </a>
      ))}
      <a
        href="#contact"
        class="block rounded-lg bg-primary px-4 py-3 text-center text-base font-semibold text-white transition-all hover:bg-primary-dark active:scale-[0.98] mt-3"
        data-menu-link
      >
        Book a discovery call
      </a>
    </nav>
  </div>
</header>

<script>
  const header = document.getElementById('site-header');
  const toggle = document.querySelector('[data-menu-toggle]');
  const menu = document.querySelector('[data-mobile-menu]');
  const menuLinks = document.querySelectorAll('[data-menu-link]');
  const bars = {
    b1: document.querySelector('[data-bar-1]'),
    b2: document.querySelector('[data-bar-2]'),
    b3: document.querySelector('[data-bar-3]'),
  };

  let isOpen = false;

  function openMenu() {
    isOpen = true;
    menu.dataset.open = 'true';
    menu.setAttribute('aria-hidden', 'false');
    toggle.setAttribute('aria-expanded', 'true');
    bars.b1.classList.add('rotate-45', 'translate-y-[8px]');
    bars.b2.classList.add('opacity-0', 'scale-0');
    bars.b3.classList.add('-rotate-45', '-translate-y-[8px]');
  }

  function closeMenu() {
    isOpen = false;
    menu.dataset.open = 'false';
    menu.setAttribute('aria-hidden', 'true');
    toggle.setAttribute('aria-expanded', 'false');
    bars.b1.classList.remove('rotate-45', 'translate-y-[8px]');
    bars.b2.classList.remove('opacity-0', 'scale-0');
    bars.b3.classList.remove('-rotate-45', '-translate-y-[8px]');
  }

  toggle.addEventListener('click', () => {
    isOpen ? closeMenu() : openMenu();
  });

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && isOpen) closeMenu();
  });

  // Close on outside click (the menu is inside header, so clicking outside would be rare)
  // Close on link click
  menuLinks.forEach((link) => {
    link.addEventListener('click', () => closeMenu());
  });

  // Scroll effect
  window.addEventListener('scroll', () => {
    const scrollY = window.scrollY;
    const inner = header.querySelector('[class*="mx-auto"]');
    if (scrollY > 40) {
      inner.classList.add('!py-2', 'md:!py-3');
      header.classList.add('shadow-sm', 'border-b', 'border-border');
    } else {
      inner.classList.remove('!py-2', 'md:!py-3');
      header.classList.remove('shadow-sm', 'border-b', 'border-border');
    }
  });
</script>
