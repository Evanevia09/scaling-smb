---
// Header / Navigation
const links = [
  { href: "#home", label: "Home" },
  { href: "#services", label: "Services" },
  { href: "#portfolio", label: "Portfolio" },
  { href: "#blog", label: "Blog" },
  { href: "#about", label: "About" },
];
---

<header class="fixed top-0 left-0 right-0 z-50 transition-all duration-500" id="site-header"
 data-scroll-header>
 <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
 <div class="flex items-center justify-between py-3 md:py-5 transition-all duration-500">
      <!-- Logo -->
      <a href="#home" class="flex items-center group shrink-0">
        <img src="/logo.jpg" alt="Scaling SMB" class="h-9 w-auto object-contain" />
      </a>

      <!-- Desktop nav -->
      <nav class="hidden md:flex items-center gap-8">
        {links.map((link) => (
          <a
            href={link.href}
            class="text-sm font-medium text-muted hover:text-dark transition-colors relative after:absolute after:bottom-[-4px] after:left-0 after:h-0.5 after:w-0 after:bg-primary after:transition-all hover:after:w-full"
          >
            {link.label}
          </a>
        ))}
        <a
          href="#contact"
          class="inline-flex items-center gap-2 rounded-lg bg-primary px-5 py-2.5 text-sm font-semibold text-white transition-all hover:bg-primary-dark active:scale-[0.97] shadow-lg shadow-primary/25"
        >
          Contact Us
          <svg width="14" height="14" viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M5 11L9 7L5 3"/>
          </svg>
        </a>
      </nav>

      <!-- Mobile menu button -->
      <button
        type="button"
        class="md:hidden relative z-50 p-3 -mr-2 text-dark touch-manipulation"
        aria-label="Toggle menu"
        data-menu-toggle
      >
        <span class="block h-0.5 w-6 bg-current transition-all duration-300" data-bar-1></span>
        <span class="block h-0.5 w-6 bg-current mt-1.5 transition-all duration-300" data-bar-2></span>
        <span class="block h-0.5 w-6 bg-current mt-1.5 transition-all duration-300" data-bar-3></span>
      </button>
    </div>
  </div>

  <!-- Mobile menu drawer -->
  <div
    class="fixed inset-0 z-40 flex flex-col bg-white/95 backdrop-blur-xl md:hidden translate-x-full transition-transform duration-500 ease-out"
    data-mobile-menu
    aria-hidden="true"
  >
    <nav class="flex flex-1 flex-col items-center justify-center gap-8 px-8">
      {links.map((link, i) => (
        <a
          href={link.href}
          class="text-3xl font-bold tracking-tight text-dark/60 hover:text-dark transition-colors"
          data-menu-link
          style={`transition-delay: ${i * 50}ms`}
        >
          {link.label}
        </a>
      ))}
      <a
        href="#contact"
        class="mt-4 inline-flex items-center gap-2 rounded-xl bg-primary px-8 py-4 text-lg font-semibold text-white transition-all hover:bg-primary-dark shadow-lg shadow-primary/25"
        data-menu-link
      >
        Contact Us
        <svg width="16" height="16" viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M5 11L9 7L5 3"/>
        </svg>
      </a>
    </nav>
  </div>
</header>

<script>
  const header = document.getElementById('site-header');
  const toggle = document.querySelector('[data-menu-toggle]');
  const menu = document.querySelector('[data-mobile-menu]');
  const links = document.querySelectorAll('[data-menu-link]');
  const bars = {
    b1: document.querySelector('[data-bar-1]'),
    b2: document.querySelector('[data-bar-2]'),
    b3: document.querySelector('[data-bar-3]'),
  };

  let isOpen = false;

  function openMenu() {
    isOpen = true;
    menu.classList.remove('translate-x-full');
    toggle.setAttribute('aria-expanded', 'true');
    menu.setAttribute('aria-hidden', 'false');
    document.body.style.overflow = 'hidden';
    bars.b1.classList.add('rotate-45', 'translate-y-[7px]');
    bars.b2.classList.add('opacity-0');
    bars.b3.classList.add('-rotate-45', '-translate-y-[7px]');
  }

  function closeMenu() {
    isOpen = false;
    menu.classList.add('translate-x-full');
    toggle.setAttribute('aria-expanded', 'false');
    menu.setAttribute('aria-hidden', 'true');
    document.body.style.overflow = '';
    bars.b1.classList.remove('rotate-45', 'translate-y-[7px]');
    bars.b2.classList.remove('opacity-0');
    bars.b3.classList.remove('-rotate-45', '-translate-y-[7px]');
  }

  toggle.addEventListener('click', () => {
    isOpen ? closeMenu() : openMenu();
  });

  // Close on Escape key
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && isOpen) closeMenu();
  });

  // Close on backdrop click (tap outside nav)
  menu.addEventListener('click', (e) => {
    if (e.target === menu) closeMenu();
  });

  links.forEach((link) => {
    link.addEventListener('click', () => closeMenu());
  });

  // Header scroll effect
  let lastScroll = 0;
  window.addEventListener('scroll', () => {
    const scrollY = window.scrollY;
    const nav = header.querySelector('div');
    if (scrollY > 50) {
      nav.classList.add('!py-3');
      header.classList.add('bg-white/90', 'backdrop-blur-xl', 'shadow-sm', 'border-b', 'border-border');
    } else {
      nav.classList.remove('!py-3');
      header.classList.remove('bg-white/90', 'backdrop-blur-xl', 'shadow-sm', 'border-b', 'border-border');
    }
    lastScroll = scrollY;
  });
</script>
