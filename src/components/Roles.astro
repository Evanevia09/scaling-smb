---
const categories = [
  {
    id: "operations",
    label: "Operations",
    icon: "gear",
    color: "text-blue-600 bg-blue-50",
    border: "border-blue-200 hover:border-blue-400",
    benefit: "Stop drowning in paperwork and repetitive tasks. Your Operations AI Employee handles data entry, invoicing, scheduling, reporting — whatever keeps your back office moving — so your team can focus on actual work.",
    tasks: [
      "Extract data from PDFs, emails, and forms into your CRM or sheets",
      "Process invoices, match to purchase orders, flag discrepancies",
      "Coordinate calendars, schedule meetings, send reminders",
      "Answer team questions on IT, HR, and company policies",
      "Compile weekly and monthly reports from multiple data sources",
      "Send onboarding packets, create accounts, collect signed documents",
      "Track inventory levels and auto-generate purchase orders",
      "Scan documents for compliance risks and log audit trails",
    ],
  },
  {
    id: "marketing",
    label: "Marketing",
    icon: "megaphone",
    color: "text-purple-600 bg-purple-50",
    border: "border-purple-200 hover:border-purple-400",
    benefit: "Never fall behind on content again. Your Marketing AI Employee writes SEO blog posts, manages social media, monitors competitors, sends email campaigns — it's like having a full marketing team that works around the clock.",
    tasks: [
      "Research keywords and write SEO-optimized blog articles",
      "Create and schedule platform-specific social media posts",
      "Track competitor websites, social channels, and ad campaigns",
      "Write and send email drip sequences with A/B testing",
      "Generate ad variations for Google, Meta, and LinkedIn",
      "Draft professional replies to Google, Yelp, and Trustpilot reviews",
      "Write video scripts for Shorts, Reels, and TikTok from your content",
      "Spin up simple landing pages with forms and copy for campaigns",
    ],
  },
  {
    id: "sales",
    label: "Sales",
    icon: "trending",
    color: "text-emerald-600 bg-emerald-50",
    border: "border-emerald-200 hover:border-emerald-400",
    benefit: "Turn every lead into a conversation and every conversation into a customer. Your Sales AI Employee qualifies leads, follows up, generates proposals, updates your CRM — so you never lose a deal because someone slipped through the cracks.",
    tasks: [
      "Chat with inbound leads, qualify them, and book meetings",
      "Send personalized follow-up sequences to leads who went cold",
      "Generate custom PDF proposals with relevant case studies",
      "Log calls, emails, and meeting notes into your CRM automatically",
      "Calculate quotes from your pricing tables and email them",
      "Answer common objections with pre-approved scripts",
      "Analyze purchase history and suggest upsells or upgrades",
      "Send satisfaction surveys and flag at-risk accounts for renewal",
    ],
  },
];
---

<section id="roles" class="py-20 sm:py-28 bg-surface">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-2xl text-center mb-16">
      <p class="text-xs font-semibold text-primary tracking-widest uppercase mb-4">AI Employees</p>
      <h2 class="text-3xl sm:text-4xl font-light tracking-tight text-heading mb-4">
        One AI employee per <span class="font-medium">department</span>
      </h2>
      <p class="text-body text-base leading-relaxed">
        Pick the department that needs support. During a free discovery call, we'll map out 
        exactly which tasks your AI Employee should handle — <strong class="text-heading font-medium">everything is customized</strong> to your business.
      </p>
    </div>

    <div class="grid gap-8 lg:grid-cols-3 max-w-6xl mx-auto">
      {categories.map((cat) => (
        <div class={`rounded-2xl border-2 ${cat.border} bg-white p-8 transition-all duration-200 hover:shadow-lg hover:shadow-${cat.id === 'operations' ? 'blue' : cat.id === 'marketing' ? 'purple' : 'emerald'}-500/5 flex flex-col`}>
          <div class="flex items-center gap-3 mb-5">
            <div class={`flex h-12 w-12 items-center justify-center rounded-xl ${cat.color}`}>
              {cat.icon === 'gear' && <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="3"/><path d="M12 1v2M12 21v2M4.22 4.22l1.42 1.42M18.36 18.36l1.42 1.42M1 12h2M21 12h2M4.22 19.78l1.42-1.42M18.36 5.64l1.42-1.42"/></svg>}
              {cat.icon === 'megaphone' && <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/><line x1="15" y1="9" x2="19" y2="9"/><line x1="15" y1="13" x2="17" y2="13"/></svg>}
              {cat.icon === 'trending' && <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M23 6l-9.5 9.5-5-5L1 18"/><polyline points="17 6 23 6 23 12"/></svg>}
            </div>
            <h3 class="text-xl font-semibold text-heading">{cat.label} <span class="text-primary/70 font-normal">AI Agent</span></h3>
          </div>

          <p class="text-sm text-body leading-relaxed mb-6">
            {cat.benefit}
          </p>

          <div class="border-t border-border pt-5 mt-auto">
            <p class="text-xs font-semibold text-heading/60 uppercase tracking-wide mb-3">What they can do for you</p>
            <ul class="space-y-2.5">
              {cat.tasks.map((task) => (
                <li class="flex items-start gap-2.5 text-sm text-body">
                  <svg class="mt-0.5 shrink-0" width="14" height="14" viewBox="0 0 14 14" fill="none">
                    <circle cx="7" cy="7" r="3.5" fill={cat.id === 'operations' ? '#2563eb' : cat.id === 'marketing' ? '#7c3aed' : '#059669'} />
                  </svg>
                  {task}
                </li>
              ))}
            </ul>
          </div>
        </div>
      ))}
    </div>

    <div class="mt-12 text-center">
      <p class="text-sm text-body mb-5">
        Not sure what you need? That's the point of the discovery call — we figure it out together.
      </p>
      <a
        href="#contact"
        class="inline-flex items-center gap-2 rounded-lg bg-primary px-6 py-3 text-sm font-semibold text-white transition-all hover:bg-primary-dark active:scale-[0.97] shadow-lg shadow-primary/25"
      >
        Book a free discovery call
        <svg width="14" height="14" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M6 12L10 8L6 4"/>
        </svg>
      </a>
    </div>
  </div>
</section>
