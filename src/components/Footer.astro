---
// Footer
---

<footer class="bg-dark text-white/70">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-16 lg:py-20">
    <div class="grid gap-12 sm:grid-cols-2 lg:grid-cols-4">
      <!-- Brand -->
      <div class="lg:col-span-1">
        <a href="#home" class="flex items-center gap-2.5 mb-4 group shrink-0">
          <img src="/logo.jpg" alt="Scaling SMB" class="h-9 w-auto object-contain brightness-0 invert" />
        </a>
        <p class="text-sm leading-relaxed text-white/50">
          Building fast, modern, scalable websites that help SMBs grow online. Based in Macau, serving APAC.
        </p>
      </div>

      <!-- Services -->
      <div>
        <h4 class="text-xs font-semibold text-white/80 uppercase tracking-widest mb-6">Services</h4>
        <ul class="space-y-3">
          <li><a href="#services" class="text-sm transition-colors hover:text-primary">Web Development</a></li>
          <li><a href="#services" class="text-sm transition-colors hover:text-primary">WeChat Mini Programs</a></li>
          <li><a href="#services" class="text-sm transition-colors hover:text-primary">Local SEO</a></li>
          <li><a href="#services" class="text-sm transition-colors hover:text-primary">Ecommerce</a></li>
          <li><a href="#services" class="text-sm transition-colors hover:text-primary">API Integration</a></li>
          <li><a href="#services" class="text-sm transition-colors hover:text-primary">AI Automations</a></li>
        </ul>
      </div>

      <!-- Company -->
      <div>
        <h4 class="text-xs font-semibold text-white/80 uppercase tracking-widest mb-6">Company</h4>
        <ul class="space-y-3">
          <li><a href="#portfolio" class="text-sm transition-colors hover:text-primary">Portfolio</a></li>
          <li><a href="#blog" class="text-sm transition-colors hover:text-primary">Blog</a></li>
          <li><a href="#about" class="text-sm transition-colors hover:text-primary">About Us</a></li>
          <li><a href="#contact" class="text-sm transition-colors hover:text-primary">Contact</a></li>
        </ul>
      </div>

      <!-- Contact -->
      <div>
        <h4 class="text-xs font-semibold text-white/80 uppercase tracking-widest mb-6">Contact</h4>
        <ul class="space-y-3 text-sm">
          <li class="flex items-center gap-2">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" class="text-primary shrink-0">
              <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
              <polyline points="22,6 12,13 2,6"/>
            </svg>
            <span class="text-white/50">evan@scalingsmb.com</span>
          </li>
          <li class="flex items-center gap-2">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" class="text-primary shrink-0">
              <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/>
            </svg>
            <span class="text-white/50">+853 6275 0705</span>
          </li>
          <li class="flex items-center gap-2">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" class="text-primary shrink-0">
              <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/>
              <circle cx="12" cy="10" r="3"/>
            </svg>
            <span class="text-white/50">Macau, APAC</span>
          </li>
        </ul>
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="mt-16 pt-8 border-t border-white/10 flex flex-col sm:flex-row justify-between items-center gap-4 text-xs text-white/40">
      <p>&copy; {new Date().getFullYear()} Scaling SMB. All rights reserved.</p>
      <div class="flex gap-6">
        <a href="#" class="hover:text-white/70 transition-colors">Privacy Policy</a>
        <a href="#" class="hover:text-white/70 transition-colors">Terms of Service</a>
      </div>
    </div>
  </div>
</footer>
