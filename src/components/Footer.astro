    <div class="flex flex-col sm:flex-row items-center justify-between gap-4">
      <div class="flex items-center gap-2">
        <span class="text-sm font-bold text-heading">scalingsmb</span>
        <span class="text-[10px] font-medium text-primary/70 bg-primary-light px-1.5 py-0.5 rounded">AI</span>
      </div>
      <p class="text-xs text-body/60">
        &copy; {year} Scaling SMB. Macau · APAC.
      </p>
      <div class="flex items-center gap-4">
        <a href="mailto:evan@scalingsmb.com" class="text-xs text-body hover:text-primary transition-colors">
          evan@scalingsmb.com
        </a>
      </div>
    </div>
  </div>
