---
import { servicesSection, services } from '../../content/site';
import servicesBg from '../../Images/bg-services/Man_standing_showing_confidence_202606021050.jpeg';
---

<section
	class="landing-section landing-services"
	id="services"
	aria-labelledby="services-title"
	style={`--services-bg-image: url(${servicesBg.src})`}
>
	<div class="landing-services__bg" aria-hidden="true"></div>

	<div class="landing-services__content">
		<div class="landing-wrap">
			<header class="landing-head" data-reveal>
				<p class="eyebrow">{servicesSection.eyebrow}</p>
				<h2 id="services-title" class="landing-head__title">{servicesSection.title}</h2>
			</header>

			<div class="services-stack" data-services-stack>
				{
					services.map((service, index) => (
						<article
							class="service-card"
							style={`--stack-index: ${index}`}
							data-service-index={index}
							data-reveal
						>
							<div class="service-card__glass">
								<div class="service-card__inner">
									<div class="service-card__header">
										<span class="service-card__number">{service.number}</span>
										<h3 class="service-card__title">{service.title}</h3>
									</div>
									<p class="service-card__tagline">{service.tagline}</p>
									<p class="service-card__desc">{service.description}</p>
									<ul class="service-card__bullets">
										{service.bullets.map((bullet) => (
											<li>{bullet}</li>
										))}
									</ul>
								</div>
							</div>
						</article>
					))
				}
				<div class="services-stack__spacer" aria-hidden="true"></div>
			</div>
		</div>
	</div>
</section>
