---
import { contact, contactFormServiceOptions } from '../../content/site';
import ConsultationBooking from './ConsultationBooking.astro';
import bookNowBg from '../../Images/book-now-bg.jpeg';

const { scheduling } = contact;
---

<section class="landing-section landing-contact" id="contact" aria-labelledby="contact-title">
	<div class="landing-contact__layout">
		<aside class="landing-contact__hero" aria-label="Contact information">
			<div
				class="landing-contact__hero-bg"
				style={`background-image: url('${bookNowBg.src}')`}
				role="presentation"
			/>
			<div class="landing-contact__hero-overlay" aria-hidden="true" />

			<div class="landing-contact__hero-content">
				<div class="landing-contact__copy" data-reveal>
					<p class="landing-contact__eyebrow">{contact.eyebrow}</p>
					<h2 id="contact-title" class="landing-contact__title">{contact.title}</h2>
					<p class="landing-contact__lede">{contact.lede}</p>
				</div>

				<div class="landing-contact__schedule-copy" data-reveal>
					<p class="landing-contact__schedule-eyebrow">{contact.scheduleEyebrow}</p>
					<h3 class="landing-contact__schedule-title">{contact.scheduleTitle}</h3>
					<p class="landing-contact__schedule-lede">{contact.scheduleLede}</p>
				</div>

				<ul class="landing-contact__details" data-reveal>
					<li class="landing-contact__detail">
						<span class="landing-contact__detail-icon" aria-hidden="true">
							<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
								<path d="M4 6h16v12H4z" />
								<path d="m4 7 8 6 8-6" stroke-linecap="round" stroke-linejoin="round" />
							</svg>
						</span>
						<div>
							<span class="landing-contact__label">Email</span>
							<a class="landing-contact__value" href={`mailto:${contact.email}`}>{contact.email}</a>
						</div>
					</li>
					<li class="landing-contact__detail">
						<span class="landing-contact__detail-icon" aria-hidden="true">
							<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
								<path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.435 9.884-9.881 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/>
							</svg>
						</span>
						<div>
							<span class="landing-contact__label">WhatsApp</span>
							<a class="landing-contact__value" href={contact.whatsappWa} target="_blank" rel="noopener noreferrer">{contact.phoneDisplay}</a>
						</div>
					</li>
					<li class="landing-contact__detail">
						<span class="landing-contact__detail-icon" aria-hidden="true">
							<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
								<path d="M12 21s7-5.2 7-11a7 7 0 1 0-14 0c0 5.8 7 11 7 11z" />
								<circle cx="12" cy="10" r="2.2" />
							</svg>
						</span>
						<div>
							<span class="landing-contact__label">Location</span>
							<span class="landing-contact__value">{contact.location}</span>
						</div>
					</li>
					<li class="landing-contact__detail">
						<span class="landing-contact__detail-icon" aria-hidden="true">
							<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
								<circle cx="12" cy="12" r="9" />
								<path d="M12 7v5l3 2" stroke-linecap="round" />
							</svg>
						</span>
						<div>
							<span class="landing-contact__label">Hours</span>
							<span class="landing-contact__value">{contact.businessHours}</span>
						</div>
					</li>
				</ul>
			</div>
		</aside>

		<div class="landing-contact__booking">
			<ConsultationBooking
				meetingTitle={scheduling.meetingTitle}
				duration={scheduling.duration}
				description={scheduling.description}
				features={[...scheduling.features]}
				timeSlots={[...scheduling.timeSlots]}
				blockedTimeSlots={[...scheduling.blockedTimeSlots]}
				timezones={[...scheduling.timezones]}
				serviceOptions={contactFormServiceOptions}
				stepLabels={[...scheduling.steps]}
				stepTitles={scheduling.stepTitles}
				success={scheduling.success}
				contactEmail={contact.email}
			/>
		</div>
	</div>
</section>
