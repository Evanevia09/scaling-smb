---
import { ctaBand } from '../../content/site';
---

<section class="landing-section landing-cta-band" id="cta" aria-labelledby="cta-title">
	<div class="landing-cta-band__geo" aria-hidden="true">
		<svg
			class="landing-cta-band__geo-svg"
			viewBox="0 0 1440 320"
			preserveAspectRatio="none"
			xmlns="http://www.w3.org/2000/svg"
		>
			<defs>
				<pattern
					id="cta-chevron"
					width="48"
					height="24"
					patternUnits="userSpaceOnUse"
					patternTransform="rotate(-24)"
				>
					<path d="M0 12 L12 0 L24 12 L12 24 Z" fill="none" stroke="rgba(255,255,255,0.07)" stroke-width="1" />
				</pattern>
			</defs>
			<rect width="1440" height="320" fill="url(#cta-chevron)" class="landing-cta-band__geo-fill" />

			<g class="landing-cta-band__geo-group landing-cta-band__geo-group--arcs">
				<path d="M 0 320 A 200 200 0 0 1 200 120" />
				<path d="M 1440 0 A 180 180 0 0 1 1260 200" />
				<path d="M 1440 320 A 140 140 0 0 0 1300 180" />
				<path d="M 0 40 A 120 120 0 0 0 100 160" />
			</g>

			<g class="landing-cta-band__geo-group landing-cta-band__geo-group--hex">
				<path d="M 95 165 L 125 113 L 185 113 L 215 165 L 185 217 L 125 217 Z" />
				<path d="M 1185 95 L 1215 43 L 1275 43 L 1305 95 L 1275 147 L 1215 147 Z" />
				<path d="M 620 45 L 650 -7 L 710 -7 L 740 45 L 710 97 L 650 97 Z" opacity="0.7" />
				<path d="M 1280 210 L 1310 158 L 1370 158 L 1400 210 L 1370 262 L 1310 262 Z" opacity="0.55" />
			</g>

			<g class="landing-cta-band__geo-group landing-cta-band__geo-group--mesh">
				<line x1="180" y1="70" x2="320" y2="130" />
				<line x1="320" y1="130" x2="480" y2="90" />
				<line x1="480" y1="90" x2="620" y2="150" />
				<line x1="620" y1="150" x2="780" y2="110" />
				<line x1="780" y1="110" x2="920" y2="170" />
				<line x1="920" y1="170" x2="1080" y2="130" />
				<line x1="1080" y1="130" x2="1240" y2="80" />
				<line x1="320" y1="130" x2="620" y2="150" />
				<line x1="780" y1="110" x2="1080" y2="130" />
				<circle cx="180" cy="70" r="4" />
				<circle cx="320" cy="130" r="4" />
				<circle cx="480" cy="90" r="4" />
				<circle cx="620" cy="150" r="4" />
				<circle cx="780" cy="110" r="5" />
				<circle cx="920" cy="170" r="4" />
				<circle cx="1080" cy="130" r="4" />
				<circle cx="1240" cy="80" r="4" />
			</g>

			<g class="landing-cta-band__geo-group landing-cta-band__geo-group--pulse">
				<circle cx="720" cy="160" r="72" />
				<circle cx="720" cy="160" r="48" />
				<circle cx="720" cy="160" r="24" />
			</g>
		</svg>
	</div>
	<div class="landing-wrap landing-cta-band__inner" data-reveal>
		<h2 id="cta-title" class="landing-cta-band__title">{ctaBand.headline}</h2>
		<a class="btn btn--primary btn--on-dark" href={ctaBand.href}>
			{ctaBand.button}
			<span aria-hidden="true"> →</span>
		</a>
	</div>
</section>
