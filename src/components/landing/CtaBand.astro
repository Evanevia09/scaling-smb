---
import { ctaBand } from '../../content/site';
---

<section class="landing-section landing-cta-band" id="cta" aria-labelledby="cta-title">
	<div class="landing-cta-band__geo" aria-hidden="true">
		<svg
			class="landing-cta-band__geo-svg"
			viewBox="0 0 1440 320"
			preserveAspectRatio="none"
			xmlns="http://www.w3.org/2000/svg"
		>
			<g class="landing-cta-band__geo-group landing-cta-band__geo-group--lines">
				<line x1="-80" y1="40" x2="1520" y2="280" />
				<line x1="-120" y1="120" x2="1560" y2="200" />
				<line x1="-60" y1="200" x2="1500" y2="60" />
				<line x1="0" y1="280" x2="1440" y2="20" />
				<line x1="200" y1="-40" x2="1240" y2="360" />
			</g>
			<g class="landing-cta-band__geo-group landing-cta-band__geo-group--grid">
				<line x1="180" y1="0" x2="180" y2="320" />
				<line x1="360" y1="0" x2="360" y2="320" />
				<line x1="540" y1="0" x2="540" y2="320" />
				<line x1="720" y1="0" x2="720" y2="320" />
				<line x1="900" y1="0" x2="900" y2="320" />
				<line x1="1080" y1="0" x2="1080" y2="320" />
				<line x1="1260" y1="0" x2="1260" y2="320" />
				<line x1="0" y1="80" x2="1440" y2="80" />
				<line x1="0" y1="160" x2="1440" y2="160" />
				<line x1="0" y1="240" x2="1440" y2="240" />
			</g>
			<g class="landing-cta-band__geo-group landing-cta-band__geo-group--shapes">
				<rect x="80" y="30" width="140" height="140" rx="4" />
				<rect x="1180" y="140" width="120" height="120" rx="4" />
				<polygon points="720,20 820,120 620,120" />
				<circle cx="320" cy="220" r="48" />
				<circle cx="1100" cy="60" r="36" />
			</g>
			<g class="landing-cta-band__geo-group landing-cta-band__geo-group--accent">
				<line x1="720" y1="0" x2="720" y2="320" />
				<line x1="0" y1="160" x2="1440" y2="160" />
				<rect x="640" y="80" width="160" height="160" rx="8" />
			</g>
		</svg>
	</div>
	<div class="landing-wrap landing-cta-band__inner" data-reveal>
		<h2 id="cta-title" class="landing-cta-band__title">{ctaBand.headline}</h2>
		<a class="btn btn--primary btn--on-dark" href={ctaBand.href}>
			{ctaBand.button}
			<span aria-hidden="true"> →</span>
		</a>
	</div>
</section>
