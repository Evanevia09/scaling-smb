---
import { projectsSection, projects } from '../../content/site';
import islandJunksImg from '../../Images/portfolio images/island-junks.jpeg';
import transpolinkImg from '../../Images/portfolio images/transpolink.jpeg';
import lofHotelImg from '../../Images/portfolio images/lof-hotel.jpeg';
import whatsordersImg from '../../Images/portfolio images/whatsorder.food.jpeg';
import type { ImageMetadata } from 'astro';

const projectImages: Record<(typeof projects)[number]['id'], ImageMetadata> = {
	'island-junks': islandJunksImg,
	transpolink: transpolinkImg,
	'lof-hotel': lofHotelImg,
	whatsorders: whatsordersImg,
};

const [featured, ...rest] = projects;
---

<section class="landing-section landing-projects" id="projects" aria-labelledby="projects-title">
	<div class="landing-wrap">
		<header class="landing-head landing-head--center" data-reveal>
			<p class="eyebrow">{projectsSection.eyebrow}</p>
			<h2 id="projects-title" class="landing-head__title">{projectsSection.title}</h2>
		</header>

		<div class="projects-layout">
			<article class="project-card project-card--lead" data-reveal>
				<div class="project-card__media">
					<img
						src={projectImages[featured.id].src}
						alt={`${featured.name} website preview`}
						loading="lazy"
						decoding="async"
					/>
				</div>
				<div class="project-card__body">
					<p class="project-card__service">{featured.service}</p>
					<h3 class="project-card__name">{featured.name}</h3>
					<p class="project-card__industry">{featured.industry}</p>
					<p class="project-card__desc">{featured.description}</p>
					{featured.quote && (
						<blockquote class="project-card__quote">
							<p>{featured.quote}</p>
						</blockquote>
					)}
				</div>
			</article>

			<div class="projects-layout__grid">
				{
					rest.map((project) => (
						<article class="project-card" data-reveal>
							<div class="project-card__media">
								<img
									src={projectImages[project.id].src}
									alt={`${project.name} website preview`}
									loading="lazy"
									decoding="async"
								/>
							</div>
							<div class="project-card__body">
								<p class="project-card__service">{project.service}</p>
								<h3 class="project-card__name">{project.name}</h3>
								<p class="project-card__industry">{project.industry}</p>
								<p class="project-card__desc">{project.description}</p>
							</div>
						</article>
					))
				}
			</div>
		</div>
	</div>
</section>
