---
import { blogListPageHref } from '../../lib/blog';

type Props = {
	page: number;
	totalPages: number;
};

const { page, totalPages } = Astro.props;
const hasPrev = page > 1;
const hasNext = page < totalPages;
---

{
	totalPages > 1 && (
		<nav class="blog-pagination" aria-label="Blog pagination">
			{hasPrev ? (
				<a class="blog-pagination__btn" href={blogListPageHref(page - 1)}>
					← Newer posts
				</a>
			) : (
				<span class="blog-pagination__btn blog-pagination__btn--disabled" aria-hidden="true">
					← Newer posts
				</span>
			)}
			<span class="blog-pagination__status">
				Page {page} of {totalPages}
			</span>
			{hasNext ? (
				<a class="blog-pagination__btn" href={blogListPageHref(page + 1)}>
					Older posts →
				</a>
			) : (
				<span class="blog-pagination__btn blog-pagination__btn--disabled" aria-hidden="true">
					Older posts →
				</span>
			)}
		</nav>
	)
}
