---
type Props = {
	title: string;
	url: string;
};

const { title, url: shareUrl } = Astro.props;
const encodedUrl = encodeURIComponent(shareUrl);
const encodedTitle = encodeURIComponent(title);
const encodedText = encodeURIComponent(`${title} — Scaling SMB`);

const shareLinks = [
	{
		id: 'x',
		label: 'Share on X',
		href: `https://twitter.com/intent/tweet?url=${encodedUrl}&text=${encodedTitle}`,
	},
	{
		id: 'facebook',
		label: 'Share on Facebook',
		href: `https://www.facebook.com/sharer/sharer.php?u=${encodedUrl}`,
	},
	{
		id: 'linkedin',
		label: 'Share on LinkedIn',
		href: `https://www.linkedin.com/sharing/share-offsite/?url=${encodedUrl}`,
	},
	{
		id: 'whatsapp',
		label: 'Share on WhatsApp',
		href: `https://wa.me/?text=${encodedText}%20${encodedUrl}`,
	},
] as const;
---

<div class="blog-share" data-blog-share data-share-url={shareUrl}>
	<p class="blog-share__label">Share this article</p>
	<div class="blog-share__actions" role="group" aria-label="Share this article">
		{
			shareLinks.map((link) => (
				<a
					class={`blog-share__btn blog-share__btn--${link.id}`}
					href={link.href}
					target="_blank"
					rel="noopener noreferrer"
					aria-label={link.label}
				>
					<span class="blog-share__icon" aria-hidden="true">
						{link.id === 'x' && '𝕏'}
						{link.id === 'facebook' && 'f'}
						{link.id === 'linkedin' && 'in'}
						{link.id === 'whatsapp' && '✓'}
					</span>
					<span class="blog-share__name">
						{link.id === 'x' ? 'X' : link.id.charAt(0).toUpperCase() + link.id.slice(1)}
					</span>
				</a>
			))
		}
		<button type="button" class="blog-share__btn blog-share__btn--copy" data-copy-link aria-label="Copy link to clipboard">
			<span class="blog-share__icon" aria-hidden="true">⎘</span>
			<span class="blog-share__name" data-copy-label>Copy link</span>
		</button>
	</div>
</div>

<script>
	import { initBlogShare } from '../../scripts/blog-share';

	initBlogShare();
</script>
