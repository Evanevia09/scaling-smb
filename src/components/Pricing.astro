---

<section id="pricing" class="py-20 sm:py-28">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-2xl text-center mb-16">
      <p class="text-xs font-semibold text-primary tracking-widest uppercase mb-4">Pricing</p>
      <h2 class="text-3xl sm:text-4xl font-light tracking-tight text-heading mb-4">
        Flat monthly fee. <span class="font-medium">No surprises.</span>
      </h2>
      <p class="text-body text-base leading-relaxed">
        No setup fees, no per-task charges, no contracts. You pay one price per role per month.
      </p>
    </div>

    <div class="grid gap-8 md:grid-cols-2 max-w-3xl mx-auto">
      <!-- Single -->
      <div class="rounded-2xl border border-border bg-white p-8 transition-all duration-200 hover:border-primary/20 hover:shadow-lg hover:shadow-primary/5">
        <h3 class="text-lg font-semibold text-heading mb-2">Single Role</h3>
        <p class="text-sm text-body mb-6">One dedicated AI employee for one department.</p>
        <div class="mb-8">
          <span class="text-4xl font-bold text-heading">$997</span>
          <span class="text-sm text-body">/month</span>
        </div>
        <ul class="space-y-3 mb-8">
          <li class="flex items-start gap-2.5 text-sm text-body">
            <svg class="mt-0.5 shrink-0" width="16" height="16" viewBox="0 0 16 16" fill="none">
              <circle cx="8" cy="8" r="4" fill="#533afd"/>
            </svg>
            One dedicated AI Employee
          </li>
          <li class="flex items-start gap-2.5 text-sm text-body">
            <svg class="mt-0.5 shrink-0" width="16" height="16" viewBox="0 0 16 16" fill="none">
              <circle cx="8" cy="8" r="4" fill="#533afd"/>
            </svg>
            Deployed on secure VPS
          </li>
          <li class="flex items-start gap-2.5 text-sm text-body">
            <svg class="mt-0.5 shrink-0" width="16" height="16" viewBox="0 0 16 16" fill="none">
              <circle cx="8" cy="8" r="4" fill="#533afd"/>
            </svg>
            Connected to your tools
          </li>
          <li class="flex items-start gap-2.5 text-sm text-body">
            <svg class="mt-0.5 shrink-0" width="16" height="16" viewBox="0 0 16 16" fill="none">
              <circle cx="8" cy="8" r="4" fill="#533afd"/>
            </svg>
            Weekly activity digest
          </li>
          <li class="flex items-start gap-2.5 text-sm text-body">
            <svg class="mt-0.5 shrink-0" width="16" height="16" viewBox="0 0 16 16" fill="none">
              <circle cx="8" cy="8" r="4" fill="#533afd"/>
            </svg>
            Cancel anytime
          </li>
        </ul>
        <a href="#contact" class="block w-full text-center rounded-lg border border-primary/20 bg-primary-light px-6 py-3 text-sm font-semibold text-primary transition-all hover:bg-primary/10">
          Get started
        </a>
      </div>

      <!-- Bundle -->
      <div class="rounded-2xl border-2 border-primary bg-white p-8 relative transition-all duration-200 hover:shadow-lg hover:shadow-primary/10">
        <div class="absolute -top-3 left-6 inline-flex items-center gap-1.5 rounded-full bg-primary px-3 py-1 text-xs font-semibold text-white">
          Most popular
        </div>
        <h3 class="text-lg font-semibold text-heading mb-2">3-Role Bundle</h3>
        <p class="text-sm text-body mb-6">One AI employee from each department: Ops, Marketing, Sales.</p>
        <div class="mb-8">
          <span class="text-4xl font-bold text-heading">$2,500</span>
          <span class="text-sm text-body">/month</span>
          <div class="mt-1 text-xs text-primary font-medium">Save $491/month vs individual roles</div>
        </div>
        <ul class="space-y-3 mb-8">
          <li class="flex items-start gap-2.5 text-sm text-body">
            <svg class="mt-0.5 shrink-0" width="16" height="16" viewBox="0 0 16 16" fill="none">
              <circle cx="8" cy="8" r="4" fill="#533afd"/>
            </svg>
            Three dedicated AI Employees
          </li>
          <li class="flex items-start gap-2.5 text-sm text-body">
            <svg class="mt-0.5 shrink-0" width="16" height="16" viewBox="0 0 16 16" fill="none">
              <circle cx="8" cy="8" r="4" fill="#533afd"/>
            </svg>
            Each on its own secure VPS
          </li>
          <li class="flex items-start gap-2.5 text-sm text-body">
            <svg class="mt-0.5 shrink-0" width="16" height="16" viewBox="0 0 16 16" fill="none">
              <circle cx="8" cy="8" r="4" fill="#533afd"/>
            </svg>
            Cross-role coordination
          </li>
          <li class="flex items-start gap-2.5 text-sm text-body">
            <svg class="mt-0.5 shrink-0" width="16" height="16" viewBox="0 0 16 16" fill="none">
              <circle cx="8" cy="8" r="4" fill="#533afd"/>
            </svg>
            Priority support
          </li>
          <li class="flex items-start gap-2.5 text-sm text-body">
            <svg class="mt-0.5 shrink-0" width="16" height="16" viewBox="0 0 16 16" fill="none">
              <circle cx="8" cy="8" r="4" fill="#533afd"/>
            </svg>
            Cancel anytime
          </li>
        </ul>
        <a href="#contact" class="block w-full text-center rounded-lg bg-primary px-6 py-3 text-sm font-semibold text-white transition-all hover:bg-primary-dark shadow-md shadow-primary/25">
          Get the bundle
        </a>
      </div>
    </div>
  </div>
</section>
