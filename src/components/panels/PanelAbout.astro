---
import { aboutPanel } from '../../content/site';
---

<section class="snap-panel snap-panel--about" id="about" aria-labelledby="about-title">
	<div class="snap-panel__inner snap-panel__inner--about content-wrap">
		<div class="about-layout">
			<div class="about-copy">
				<p class="eyebrow">{aboutPanel.eyebrow}</p>
				<h2 id="about-title" class="about-title">
					{aboutPanel.titleBefore}<span class="text-accent">{aboutPanel.titleAccent}</span>{aboutPanel.titleAfter}
				</h2>
				<p class="about-lede">{aboutPanel.lede}</p>
				{
					aboutPanel.paragraphs.map((p) => (
						<p class="about-para">{p}</p>
					))
				}
				<a class="btn btn--primary about-cta" href={aboutPanel.ctaHref}>
					{aboutPanel.cta}
				</a>
			</div>

			<div class="about-aside">
				<ul class="about-values">
					{
						aboutPanel.values.map((v) => (
							<li class="about-value">
								<h3 class="about-value__title">{v.title}</h3>
								<p class="about-value__desc">{v.description}</p>
							</li>
						))
					}
				</ul>

				<dl class="about-stats">
					{
						aboutPanel.stats.map((s) => (
							<div class="about-stat">
								<dt class="about-stat__value">{s.value}</dt>
								<dd class="about-stat__label">{s.label}</dd>
							</div>
						))
					}
				</dl>
			</div>
		</div>
	</div>
</section>

<style>
	.snap-panel--about {
		background: var(--bg-subtle);
	}

	.snap-panel__inner--about {
		display: flex;
		align-items: center;
		justify-content: center;
		padding-block: clamp(1rem, 2vh, 1.5rem);
		min-height: 0;
	}

	.about-layout {
		display: grid;
		grid-template-columns: minmax(0, 1.1fr) minmax(0, 0.9fr);
		gap: clamp(1.5rem, 4vw, 2.5rem);
		align-items: start;
		width: 100%;
	}

	.about-copy {
		text-align: left;
	}

	.about-title {
		margin: 0 0 0.75rem;
		font-size: clamp(1.65rem, 3vw, 2.35rem);
		font-weight: 800;
		letter-spacing: -0.03em;
		line-height: 1.12;
		color: var(--text);
	}

	.text-accent {
		color: var(--accent);
	}

	.about-lede {
		margin: 0 0 1rem;
		font-size: clamp(1rem, 1.5vw, 1.1rem);
		line-height: 1.55;
		color: var(--text);
		font-weight: 500;
	}

	.about-para {
		margin: 0 0 0.85rem;
		font-size: 0.98rem;
		line-height: 1.6;
		color: var(--text-muted);
		max-width: 36rem;
	}

	.about-cta {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		min-height: 44px;
		margin-top: 0.5rem;
		padding: 0.65rem 1.5rem;
		border-radius: 8px;
		font-weight: 600;
		font-size: 0.95rem;
		text-decoration: none;
		background: var(--accent);
		color: #fff !important;
		border: 1px solid transparent;
		box-shadow: 0 8px 24px rgba(0, 85, 255, 0.25);
	}

	.about-cta:hover {
		background: var(--accent-strong);
		color: #fff !important;
		text-decoration: none;
	}

	.about-aside {
		display: flex;
		flex-direction: column;
		gap: 1.25rem;
	}

	.about-values {
		list-style: none;
		margin: 0;
		padding: 0;
		display: flex;
		flex-direction: column;
		gap: 0.75rem;
	}

	.about-value {
		padding: 1rem 1.1rem;
		border-radius: var(--radius-md);
		background: #fff;
		border: 1px solid var(--border);
	}

	.about-value__title {
		margin: 0 0 0.35rem;
		font-size: 0.95rem;
		font-weight: 800;
		color: var(--text);
	}

	.about-value__desc {
		margin: 0;
		font-size: 0.88rem;
		line-height: 1.5;
		color: var(--text-muted);
	}

	.about-stats {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: 0.65rem;
		margin: 0;
	}

	.about-stat {
		display: flex;
		flex-direction: column;
		align-items: center;
		text-align: center;
		padding: 0.85rem 0.5rem;
		border-radius: var(--radius-md);
		background: #fff;
		border: 1px solid var(--border);
	}

	.about-stat__value {
		margin: 0;
		font-size: clamp(1.25rem, 2vw, 1.5rem);
		font-weight: 800;
		letter-spacing: -0.03em;
		color: var(--accent);
	}

	.about-stat__label {
		margin: 0.2rem 0 0;
		font-size: 0.68rem;
		font-weight: 700;
		letter-spacing: 0.05em;
		text-transform: uppercase;
		color: var(--text-muted);
	}

	@media (max-width: 860px) {
		.about-layout {
			grid-template-columns: 1fr;
		}

		.about-stats {
			grid-template-columns: repeat(3, 1fr);
		}
	}

	@media (max-width: 480px) {
		.about-stats {
			grid-template-columns: 1fr;
		}

		.about-stat {
			flex-direction: row;
			justify-content: space-between;
			text-align: left;
			padding-inline: 1rem;
		}
	}
</style>
