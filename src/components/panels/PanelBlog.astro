---
import { blogPanel, blogPosts } from '../../content/site';
---

<section class="snap-panel snap-panel--blog" id="blog" aria-labelledby="blog-title">
	<div class="snap-panel__inner snap-panel__inner--blog content-wrap">
		<header class="blog-head">
			<p class="eyebrow">{blogPanel.eyebrow}</p>
			<h2 id="blog-title" class="blog-head__title">
				{blogPanel.titleBefore}<span class="text-accent">{blogPanel.titleAccent}</span>{blogPanel.titleAfter}
			</h2>
			<p class="blog-head__lede">{blogPanel.lede}</p>
		</header>

		<ul class="blog-grid">
			{
				blogPosts.map((post) => (
					<li>
						<article class="blog-card">
							<div class="blog-card__meta">
								<span class="blog-card__category">{post.category}</span>
								<span class="blog-card__dot" aria-hidden="true">
									·
								</span>
								<time class="blog-card__date" datetime={post.date}>{post.date}</time>
							</div>
							<h3 class="blog-card__title">
								<a class="blog-card__link" href="#contact">
									{post.title}
								</a>
							</h3>
							<p class="blog-card__excerpt">{post.excerpt}</p>
							<p class="blog-card__read">{post.readTime}</p>
						</article>
					</li>
				))
			}
		</ul>

		<footer class="blog-foot">
			<a class="btn btn--primary blog-foot__btn" href={blogPanel.ctaHref}>
				{blogPanel.cta}
			</a>
		</footer>
	</div>
</section>

<style>
	.snap-panel--blog {
		background: #fff;
	}

	.snap-panel__inner--blog {
		display: flex;
		flex-direction: column;
		justify-content: center;
		gap: clamp(1.25rem, 2.5vh, 1.75rem);
		padding-block: clamp(1rem, 2vh, 1.5rem);
		min-height: 0;
	}

	.blog-head {
		text-align: center;
		max-width: 40rem;
		margin-inline: auto;
	}

	.blog-head__title {
		margin: 0 0 0.5rem;
		font-size: clamp(1.65rem, 3vw, 2.25rem);
		font-weight: 800;
		letter-spacing: -0.03em;
		line-height: 1.12;
		color: var(--text);
	}

	.text-accent {
		color: var(--accent);
	}

	.blog-head__lede {
		margin: 0;
		font-size: clamp(0.95rem, 1.5vw, 1.05rem);
		line-height: 1.55;
		color: var(--text-muted);
	}

	.blog-grid {
		list-style: none;
		margin: 0;
		padding: 0;
		display: grid;
		grid-template-columns: repeat(2, 1fr);
		gap: clamp(0.75rem, 1.5vw, 1rem);
		width: 100%;
	}

	.blog-card {
		height: 100%;
		display: flex;
		flex-direction: column;
		padding: 1.15rem 1.2rem;
		border: 1px solid var(--border);
		border-radius: var(--radius-md);
		background: var(--bg-subtle);
		transition:
			border-color 0.25s ease,
			box-shadow 0.25s ease;
	}

	.blog-card:hover {
		border-color: rgba(0, 85, 255, 0.25);
		box-shadow: var(--shadow-sm);
	}

	.blog-card__meta {
		display: flex;
		flex-wrap: wrap;
		align-items: center;
		gap: 0.35rem;
		margin-bottom: 0.5rem;
		font-size: 0.75rem;
		font-weight: 600;
		color: var(--text-muted);
	}

	.blog-card__category {
		color: var(--accent);
		text-transform: uppercase;
		letter-spacing: 0.06em;
	}

	.blog-card__dot {
		opacity: 0.5;
	}

	.blog-card__title {
		margin: 0 0 0.45rem;
		font-size: 1.05rem;
		font-weight: 800;
		line-height: 1.3;
		letter-spacing: -0.02em;
	}

	.blog-card__link {
		color: var(--text) !important;
		text-decoration: none;
	}

	.blog-card__link:hover {
		color: var(--accent) !important;
	}

	.blog-card__excerpt {
		margin: 0;
		flex: 1;
		font-size: 0.9rem;
		line-height: 1.55;
		color: var(--text-muted);
		display: -webkit-box;
		-webkit-line-clamp: 3;
		-webkit-box-orient: vertical;
		overflow: hidden;
	}

	.blog-card__read {
		margin: 0.65rem 0 0;
		font-size: 0.78rem;
		font-weight: 600;
		color: var(--text-muted);
	}

	.blog-foot {
		display: flex;
		justify-content: center;
	}

	.blog-foot__btn {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		min-height: 44px;
		padding: 0.65rem 1.5rem;
		border-radius: 8px;
		font-weight: 600;
		font-size: 0.95rem;
		text-decoration: none;
		background: var(--accent);
		color: #fff !important;
		border: 1px solid transparent;
		box-shadow: 0 8px 24px rgba(0, 85, 255, 0.25);
	}

	.blog-foot__btn:hover {
		background: var(--accent-strong);
		color: #fff !important;
		text-decoration: none;
	}

	@media (max-width: 720px) {
		.blog-grid {
			grid-template-columns: 1fr;
		}
	}
</style>
