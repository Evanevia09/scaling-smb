---
import '../styles/global.css';
import { brand, seo as seoDefaults } from '../content/site';
import { getSiteOrigin } from '../lib/seo';

type Props = {
	title?: string;
	description?: string;
	ogImage?: string;
	ogType?: 'website' | 'article';
	/** Shorter headline for social cards (defaults to `title`) */
	ogTitle?: string;
	articlePublishedTime?: string;
	articleModifiedTime?: string;
	/** Pagination / series */
	prevUrl?: string;
	nextUrl?: string;
	noindex?: boolean;
};

const {
	title = seoDefaults.title,
	description = seoDefaults.description,
	ogImage = seoDefaults.defaultOgImage,
	ogType = 'website',
	ogTitle,
	articlePublishedTime,
	articleModifiedTime,
	prevUrl,
	nextUrl,
	noindex = false,
} = Astro.props;
const socialTitle = ogTitle ?? title;
const canonical = new URL(Astro.url.pathname, Astro.site).href;
const ogUrl = Astro.site ? new URL(Astro.url.pathname, Astro.site).href : canonical;
const twitterCard = ogImage ? 'summary_large_image' : 'summary';
const ogImageAbsolute = ogImage
	? ogImage.startsWith('http')
		? ogImage
		: new URL(ogImage, Astro.site ?? 'https://scalingsmb.com').href
	: undefined;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<title>{title}</title>
		<meta name="description" content={description} />
		<meta
			name="robots"
			content={noindex ? 'noindex, follow' : 'index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1'}
		/>
		<link rel="canonical" href={canonical} />
		{prevUrl && <link rel="prev" href={prevUrl} />}
		{nextUrl && <link rel="next" href={nextUrl} />}
		<link
			rel="alternate"
			type="application/rss+xml"
			title={`${brand.name} Blog`}
			href={`${getSiteOrigin(Astro.site)}/rss.xml`}
		/>
		<meta property="og:type" content={ogType} />
		<meta property="og:site_name" content="Scaling SMB" />
		<meta property="og:title" content={socialTitle} />
		<meta property="og:description" content={description} />
		<meta property="og:url" content={ogUrl} />
		<meta property="og:locale" content="en_US" />
		{ogType === 'article' && articlePublishedTime && (
			<meta property="article:published_time" content={articlePublishedTime} />
		)}
		{ogType === 'article' && articleModifiedTime && (
			<meta property="article:modified_time" content={articleModifiedTime} />
		)}
		{ogImageAbsolute && (
			<>
				<meta property="og:image" content={ogImageAbsolute} />
				<meta property="og:image:secure_url" content={ogImageAbsolute} />
				<meta property="og:image:width" content="1200" />
				<meta property="og:image:height" content="630" />
				<meta property="og:image:alt" content={title} />
			</>
		)}
		<meta name="twitter:card" content={twitterCard} />
		<meta name="twitter:title" content={socialTitle} />
		<meta name="twitter:description" content={description} />
		{ogImageAbsolute && <meta name="twitter:image" content={ogImageAbsolute} />}
		<link rel="icon" href="/favicon.ico" sizes="any" />
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			href="https://fonts.googleapis.com/css2?family=Inter:ital,opsz,wght@0,14..32,400..700;1,14..32,400..700&display=swap"
			rel="stylesheet"
		/>
	</head>
	<body>
		<!-- Google tag (gtag.js) -->
		<script async src="https://www.googletagmanager.com/gtag/js?id=G-2LLXSEPMTH"></script>
		<script is:inline>
			window.dataLayer = window.dataLayer || [];
			function gtag(){dataLayer.push(arguments);}
			gtag('js', new Date());
			gtag('config', 'G-2LLXSEPMTH');
		</script>
		<a class="skip-link" href="#main">Skip to content</a>
		<div class="shell">
			<slot />
		</div>
		<script>
			import { initReveal } from '../scripts/reveal';
			import { initSectionNav } from '../scripts/section-nav';
			import { initSiteHeader } from '../scripts/site-header';
			import { initSiteHeaderScroll } from '../scripts/site-header-scroll';
			import { initProcessTimeline } from '../scripts/process-timeline';
			initReveal();
			initSectionNav();
			initSiteHeader();
			initSiteHeaderScroll();
			initProcessTimeline();
		</script>
	</body>
</html>
