---
import BaseLayout from './BaseLayout.astro';
import { brand } from '../content/site';

type ClientInfo = {
	name: string;
	url?: string;
	tagline?: string;
	service?: string;
};

type AuditMeta = {
	client: ClientInfo;
	reportDate?: string;
	period?: string;
	auditedBy?: string;
};

const { client, reportDate, period, auditedBy } = Astro.props as AuditMeta;
const rd = reportDate || new Date().toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
const ab = auditedBy || `${brand.name} — Google Ads Specialist`;
---

<BaseLayout
	title={`Digital Marketing Audit — ${client.name} | ${brand.name}`}
	description={`Comprehensive digital marketing audit for ${client.name}: Google Ads performance analysis, Search Console data, and actionable recommendations.`}
	noindex={true}
>
	<main id="main" class="audit-report">
		<!-- Hero -->
		<section class="report-hero">
			<div class="wrapper">
				<p class="eyebrow">Confidential Client Report &mdash; {rd}</p>
				<h1>Digital Marketing Audit<br /><span class="client-name">{client.name}</span></h1>
				{client.tagline && <p class="subtitle">{client.tagline}</p>}
				<div class="meta-grid">
					<div class="meta-item">
						<span class="label">Audited By</span>
						<span class="value">{ab}</span>
					</div>
					{period && <div class="meta-item"><span class="label">Period</span><span class="value">{period}</span></div>}
					{client.url && <div class="meta-item"><span class="label">Website</span><span class="value"><a href={client.url} target="_blank">{client.url}</a></span></div>}
				</div>
			</div>
		</section>

		<slot name="content" />

		<!-- Next Steps -->
		<section class="section cta-section">
			<div class="wrapper">
				<h2><span class="section-icon">🚀</span> Next Steps</h2>
				<div class="next-steps-grid">
					<div class="next-step">
						<span class="step-number">1</span>
						<h4>Review &amp; Discuss</h4>
						<p>Let&rsquo;s schedule a 30-minute call to walk through these findings and answer any questions.</p>
					</div>
					<div class="next-step">
						<span class="step-number">2</span>
						<h4>Quick Wins</h4>
						<p>We can implement high-priority items (conversion tracking, negative keywords) within 48 hours of approval.</p>
					</div>
					<div class="next-step">
						<span class="step-number">3</span>
						<h4>Full Campaign Restructure</h4>
						<p>Build and launch the recommended campaign restructure within 1 week of sign-off.</p>
					</div>
				</div>
				<p class="report-footer">This report was generated using live data from Google Ads API and Google Search Console.</p>
			</div>
		</section>
	</main>
</BaseLayout>

<style is:global>
	.audit-report { background: #fff; color: #1a1a2e; }
	.wrapper { max-width: 960px; margin: 0 auto; padding: 0 24px; }
	.section { padding: 48px 0; border-bottom: 1px solid #e8e8f0; }
	.section:last-of-type { border-bottom: none; }
	h2 { font-size: 1.5rem; font-weight: 700; margin: 0 0 24px; color: #1a1a2e; display: flex; align-items: center; gap: 10px; }
	h3 { font-size: 1.15rem; font-weight: 600; margin: 32px 0 16px; color: #2d2d4e; }
	h4 { font-size: 1rem; font-weight: 600; margin: 0 0 8px; color: #1a1a2e; }
	p { line-height: 1.7; margin: 0 0 16px; color: #444; }
	.section-icon { font-size: 1.4rem; }
	.report-hero { background: linear-gradient(135deg, #1a1a2e 0%, #16213e 100%); color: #fff; padding: 64px 0 48px; }
	.report-hero .eyebrow { font-size: 0.8rem; text-transform: uppercase; letter-spacing: 2px; color: #a0a0c0; margin-bottom: 16px; }
	.report-hero h1 { font-size: 2.4rem; font-weight: 800; margin: 0 0 12px; line-height: 1.2; }
	.report-hero .client-name { color: #d4a854; }
	.report-hero .subtitle { font-size: 1.1rem; color: #b0b0d0; margin-bottom: 32px; }
	.meta-grid { display: flex; gap: 40px; flex-wrap: wrap; }
	.meta-item .label { display: block; font-size: 0.75rem; text-transform: uppercase; letter-spacing: 1px; color: #8080a8; margin-bottom: 4px; }
	.meta-item .value { font-size: 0.95rem; color: #d0d0f0; }
	.meta-item a { color: #d4a854; text-decoration: underline; }
	.kpi-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(180px, 1fr)); gap: 16px; margin: 24px 0; }
	.kpi-card { background: #f8f8ff; border-radius: 12px; padding: 24px; text-align: center; border: 1px solid #e0e0f0; }
	.kpi-card.warn { border-left: 4px solid #f0a030; }
	.kpi-card.danger { border-left: 4px solid #d32f2f; }
	.kpi-card.neutral { border-left: 4px solid #607d8b; }
	.kpi-card.good { border-left: 4px solid #2e7d32; }
	.kpi-value { font-size: 2.2rem; font-weight: 800; color: #1a1a2e; display: block; }
	.kpi-value small { font-size: 1rem; font-weight: 400; color: #777; margin-left: 2px; }
	.kpi-label { font-size: 0.8rem; color: #777; display: block; margin-top: 4px; text-transform: uppercase; letter-spacing: 0.5px; }
	.alert { border-radius: 10px; padding: 20px 24px; margin: 24px 0; line-height: 1.6; font-size: 0.95rem; }
	.alert-high { background: #fff3e0; border: 1px solid #ffe0b2; color: #e65100; }
	.alert-danger { background: #ffebee; border: 1px solid #ffcdd2; color: #c62828; }
	.alert-warn { background: #fff8e1; border: 1px solid #ffecb3; color: #f57f17; }
	.content-card { background: #f8f8ff; border-radius: 12px; padding: 24px; border: 1px solid #e8e8f0; }
	.info-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; margin-top: 16px; font-size: 0.9rem; color: #555; }
	.info-grid div { padding: 8px 0; border-top: 1px solid #e8e8f0; }
	.data-table { width: 100%; border-collapse: collapse; margin: 16px 0; font-size: 0.88rem; }
	.data-table th { background: #f0f0f8; text-align: left; padding: 12px; font-weight: 600; color: #333; border-bottom: 2px solid #d0d0e0; }
	.data-table td { padding: 10px 12px; border-bottom: 1px solid #e8e8f0; vertical-align: top; }
	.data-table small { font-size: 0.78rem; color: #888; }
	.row-danger td { background: #fff5f5; }
	.row-paused td { background: #fff8e1; }
	.row-removed td { color: #999; font-style: italic; }
	.row-neutral td { background: #fafafa; }
	.row-good td { background: #f5fff5; }
	.badge { display: inline-block; font-size: 0.75rem; font-weight: 600; padding: 2px 8px; border-radius: 4px; }
	.badge-enabled { background: #e8f5e9; color: #2e7d32; }
	.badge-paused { background: #fff8e1; color: #f57f17; }
	.badge-removed { background: #f0f0f0; color: #888; }
	.badge-fail { background: #ffebee; color: #c62828; }
	.badge-neutral { background: #f0f0f8; color: #607d8b; }
	.tag { display: inline-block; font-size: 0.75rem; font-weight: 600; padding: 2px 10px; border-radius: 12px; }
	.tag-bad { background: #ffebee; color: #c62828; }
	.tag-good { background: #e8f5e9; color: #2e7d32; }
	.tag-neutral { background: #f0f0f8; color: #607d8b; }
	.findings-list { list-style: none; padding: 0; margin: 16px 0; }
	.findings-list li { padding: 10px 0; border-bottom: 1px solid #eee; line-height: 1.6; }
	.findings-list li:last-child { border-bottom: none; }
	.priority-block { margin-bottom: 32px; }
	.priority-tag { display: inline-block; font-size: 0.75rem; font-weight: 700; padding: 3px 10px; border-radius: 4px; margin-right: 8px; }
	.priority-p0 .priority-tag { background: #d32f2f; color: #fff; }
	.priority-p1 .priority-tag { background: #f57f17; color: #fff; }
	.priority-p2 .priority-tag { background: #1976d2; color: #fff; }
	.priority-p3 .priority-tag { background: #607d8b; color: #fff; }
	.rec-card { background: #f8f8ff; border-radius: 12px; padding: 24px; margin-bottom: 16px; border: 1px solid #e8e8f0; }
	.rec-card ul { margin: 8px 0 0 20px; line-height: 1.7; }
	.rec-card ul li { margin-bottom: 4px; }
	.effort { display: inline-block; font-size: 0.8rem; font-weight: 500; padding: 2px 8px; border-radius: 4px; margin-right: 8px; }
	.effort-easy { background: #e8f5e9; color: #2e7d32; }
	.effort-medium { background: #fff8e1; color: #f57f17; }
	.effort-hard { background: #ffebee; color: #c62828; }
	.impact { display: inline-block; font-size: 0.8rem; font-weight: 500; }
	.impact-high { color: #d32f2f; }
	.impact-medium { color: #f57f17; }
	.impact-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 16px; }
	.impact-card { background: linear-gradient(135deg, #1a1a2e, #16213e); color: #fff; border-radius: 12px; padding: 28px 24px; text-align: center; }
	.impact-card h4 { color: #d4a854; margin-bottom: 8px; }
	.impact-card p { color: #b0b0d0; font-size: 0.85rem; margin: 0; }
	.impact-number { font-size: 2.6rem !important; font-weight: 800 !important; color: #fff !important; margin-bottom: 4px !important; }
	.impact-number span { font-size: 1rem; font-weight: 400; color: #8888bb; }
	.methodology-steps { display: grid; grid-template-columns: repeat(auto-fill, minmax(140px, 1fr)); gap: 12px; margin: 20px 0; }
	.step { background: #f0f0f8; border-radius: 8px; padding: 12px; text-align: center; font-size: 0.85rem; font-weight: 500; color: #333; }
	.step-num { display: block; font-size: 1.5rem; font-weight: 800; color: #d4a854; margin-bottom: 4px; }
	.next-steps-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(240px, 1fr)); gap: 20px; margin: 24px 0; }
	.next-step { background: #f8f8ff; border-radius: 12px; padding: 28px; border: 1px solid #e8e8f0; text-align: center; }
	.step-number { display: block; font-size: 2rem; font-weight: 800; color: #d4a854; margin-bottom: 8px; }
	.next-step h4 { margin-bottom: 8px; }
	.next-step p { font-size: 0.9rem; margin: 0; }
	.cta-section { background: #fafaff; }
	.report-footer { margin-top: 40px; font-size: 0.8rem; color: #999; text-align: center; border-top: 1px solid #e8e8f0; padding-top: 24px; }
	@media (max-width: 768px) {
		.report-hero h1 { font-size: 1.6rem; }
		.kpi-grid { grid-template-columns: 1fr 1fr; }
		.meta-grid { flex-direction: column; gap: 16px; }
		.data-table { font-size: 0.78rem; overflow-x: auto; display: block; }
		.info-grid { grid-template-columns: 1fr; }
	}
</style>
