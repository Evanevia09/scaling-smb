---
import BaseLayout from './BaseLayout.astro';
import { brand } from '../content/site';

type ClientInfo = {
	name: string;
	url?: string;
	tagline?: string;
	service?: string;
};

type AuditMeta = {
	client: ClientInfo;
	reportDate?: string;
	period?: string;
	auditedBy?: string;
};

const { client, reportDate, period, auditedBy } = Astro.props as AuditMeta;
const rd = reportDate || new Date().toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
const ab = auditedBy || `${brand.name} — Google Ads Specialist`;
---

<BaseLayout
	title={`Digital Marketing Audit — ${client.name} | ${brand.name}`}
	description={`Comprehensive digital marketing audit for ${client.name}: Google Ads performance analysis, Search Console data, and actionable recommendations.`}
	noindex={true}
>
	<main id="main" class="audit-report">
		<!-- Hero -->
		<section class="report-hero">
			<div class="wrapper">
				<p class="eyebrow">Confidential Client Report &mdash; {rd}</p>
				<h1>Digital Marketing Audit<br /><span class="client-name">{client.name}</span></h1>
				{client.tagline && <p class="subtitle">{client.tagline}</p>}
				<div class="meta-grid">
					<div class="meta-item">
						<span class="label">Audited By</span>
						<span class="value">{ab}</span>
					</div>
					{period && <div class="meta-item"><span class="label">Period</span><span class="value">{period}</span></div>}
					{client.url && <div class="meta-item"><span class="label">Website</span><span class="value"><a href={client.url} target="_blank">{client.url}</a></span></div>}
				</div>
			</div>
		</section>

		<slot name="content" />

		<!-- CTA Modal Trigger -->
		<section class="section cta-section">
			<div class="wrapper">
				<div class="cta-card">
					<h2>Ready to act on these findings?</h2>
					<p>Let's schedule a 30-minute strategy call to walk through the audit, answer your questions, and build a plan tailored to your business.</p>
					<button class="cta-btn" id="ctaModalBtn" onclick="document.getElementById('ctaOverlay').classList.add('open')">
						Book Your Free Strategy Call
					</button>
				</div>
				<p class="report-footer">This report was generated using live data from Google Ads API and Google Search Console.</p>
			</div>
		</section>

		<!-- CTA Modal -->
		<div class="modal-overlay" id="ctaOverlay" onclick="if(event.target===this)this.classList.remove('open')">
			<div class="modal-card">
				<button class="modal-close" onclick="document.getElementById('ctaOverlay').classList.remove('open')" aria-label="Close">&times;</button>
				<div class="modal-body">
					<span class="modal-icon">📞</span>
					<h3>Book Your Strategy Call</h3>
					<p class="modal-sub">Pick the best time for a 30-minute call. We'll review your audit findings and build your action plan.</p>
					<div class="modal-options">
						<a href="/#contact" class="modal-btn modal-btn-primary">
							<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
							<span>Schedule via Booking Calendar</span>
						</a>
						<a href="mailto:evan@scalingsmb.com?subject=Audit%20Follow-Up%3A%20{encodeURIComponent(client.name)}&body=Hi%20Evan%2C%0A%0AI%27ve%20reviewed%20the%20audit%20for%20{encodeURIComponent(client.name)}.%20Let%27s%20schedule%20our%20strategy%20call." class="modal-btn modal-btn-secondary">
							<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
							<span>Email Us Directly</span>
						</a>
					</div>
					<p class="modal-note">No commitment. No pressure. Just a conversation about what's possible.</p>
				</div>
			</div>
		</div>
	</main>

	<script>
		// Modal keyboard support
		document.addEventListener('keydown', (e) => {
			if (e.key === 'Escape') {
				document.getElementById('ctaOverlay')?.classList.remove('open');
			}
		});
	</script>
</BaseLayout>

<style is:global>
	/* ── Main site design tokens ── */
	.audit-report { font-family: 'Inter', system-ui, -apple-system, sans-serif; background: var(--bg, #ffffff); color: var(--text, #0f172a); }
	.wrapper { max-width: var(--content-max, 72rem); margin: 0 auto; padding: 0 var(--section-gutter, 1.25rem); }
	.section { padding: var(--space-section, 4rem) 0; border-bottom: 1px solid var(--border, rgba(15,23,42,0.1)); }
	.section:last-of-type { border-bottom: none; }

	h2 { font-size: 1.5rem; font-weight: 700; margin: 0 0 24px; color: var(--text, #0f172a); display: flex; align-items: center; gap: 10px; }
	h3 { font-size: 1.15rem; font-weight: 600; margin: 32px 0 16px; color: var(--text, #0f172a); }
	h4 { font-size: 1rem; font-weight: 600; margin: 0 0 8px; color: var(--text, #0f172a); }
	p { line-height: 1.7; margin: 0 0 16px; color: var(--text-muted, #525866); }
	.section-icon { font-size: 1.4rem; }

	/* ── Hero ── */
	.report-hero { background: var(--text, #0f172a); color: #fff; padding: 5rem 0 4rem; }
	.report-hero .eyebrow { font-size: 0.8rem; text-transform: uppercase; letter-spacing: 2px; color: rgba(255,255,255,0.5); margin-bottom: 16px; }
	.report-hero h1 { font-size: 2.6rem; font-weight: 800; margin: 0 0 12px; line-height: 1.15; letter-spacing: -0.02em; }
	.report-hero .client-name { color: var(--accent, #0055ff); }
	.report-hero .subtitle { font-size: 1.1rem; color: rgba(255,255,255,0.6); margin-bottom: 32px; }
	.meta-grid { display: flex; gap: 40px; flex-wrap: wrap; }
	.meta-item .label { display: block; font-size: 0.7rem; text-transform: uppercase; letter-spacing: 1px; color: rgba(255,255,255,0.4); margin-bottom: 4px; }
	.meta-item .value { font-size: 0.95rem; color: rgba(255,255,255,0.85); }
	.meta-item a { color: var(--accent, #0055ff); text-decoration: underline; }

	/* ── KPI Chart Blocks ── */
	.kpi-charts { display: flex; flex-direction: column; gap: 12px; margin: 24px 0; }
	.kpi-chart-row { display: flex; align-items: center; gap: 16px; }
	.kpi-chart-label { flex: 0 0 140px; font-size: 0.85rem; font-weight: 600; color: var(--text, #0f172a); text-align: right; }
	.kpi-chart-bar-wrap { flex: 1; background: var(--bg-subtle, #f6f8fc); border-radius: 8px; height: 32px; overflow: hidden; position: relative; }
	.kpi-chart-bar { height: 100%; border-radius: 8px; display: flex; align-items: center; padding: 0 12px; transition: width 0.6s var(--ease-out, cubic-bezier(0.22,1,0.36,1)); }
	.kpi-chart-bar-value { font-size: 0.8rem; font-weight: 700; color: #fff; white-space: nowrap; }
	.kpi-chart-val { flex: 0 0 100px; font-size: 0.9rem; font-weight: 700; color: var(--text, #0f172a); }
	.bar-red { background: #ef4444; }
	.bar-orange { background: #f59e0b; }
	.bar-blue { background: var(--accent, #0055ff); }
	.bar-green { background: #10b981; }
	.bar-teal { background: #06b6d4; }
	.bar-purple { background: #8b5cf6; }
	.bar-gray { background: #94a3b8; }

	/* ── KPI Grid (for simple metrics) ── */
	.kpi-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(180px, 1fr)); gap: 16px; margin: 24px 0; }
	.kpi-card { background: var(--bg-subtle, #f6f8fc); border-radius: var(--radius-md, 12px); padding: 24px; text-align: center; }
	.kpi-value { font-size: 2.2rem; font-weight: 800; color: var(--text, #0f172a); display: block; letter-spacing: -0.02em; }
	.kpi-value small { font-size: 0.9rem; font-weight: 400; color: var(--text-muted, #525866); }
	.kpi-label { font-size: 0.75rem; color: var(--text-muted, #525866); display: block; margin-top: 6px; text-transform: uppercase; letter-spacing: 0.5px; font-weight: 500; }

	/* ── Alerts ── */
	.alert { border-radius: var(--radius-md, 12px); padding: 20px 24px; margin: 24px 0; line-height: 1.6; font-size: 0.95rem; }
	.alert-critical { background: #fef2f2; border: 1px solid #fecaca; color: #dc2626; }
	.alert-high { background: #fff7ed; border: 1px solid #fed7aa; color: #c2410c; }
	.alert-warn { background: #fffbeb; border: 1px solid #fde68a; color: #b45309; }
	.alert-info { background: #eff6ff; border: 1px solid #bfdbfe; color: #1d4ed8; }

	/* ── Content Card ── */
	.content-card { background: var(--bg-subtle, #f6f8fc); border-radius: var(--radius-md, 12px); padding: 24px; }
	.info-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; margin-top: 16px; font-size: 0.9rem; color: var(--text-muted, #525866); }
	.info-grid div { padding: 8px 0; border-top: 1px solid var(--border, rgba(15,23,42,0.1)); }

	/* ── Tables ── */
	.data-table { width: 100%; border-collapse: separate; border-spacing: 0; margin: 16px 0; font-size: 0.88rem; border-radius: var(--radius-md, 12px); overflow: hidden; border: 1px solid var(--border, rgba(15,23,42,0.1)); }
	.data-table th { background: var(--bg-subtle, #f6f8fc); text-align: left; padding: 12px 16px; font-weight: 600; color: var(--text, #0f172a); font-size: 0.8rem; text-transform: uppercase; letter-spacing: 0.5px; }
	.data-table td { padding: 12px 16px; border-top: 1px solid var(--border, rgba(15,23,42,0.1)); vertical-align: top; }
	.data-table small { font-size: 0.78rem; color: var(--text-muted, #525866); }
	.row-danger td { background: #fef2f2; }
	.row-paused td { background: #fffbeb; }
	.row-removed td { color: var(--text-muted, #525866); font-style: italic; }
	.row-good td { background: #f0fdf4; }

	/* ── Badges & Tags ── */
	.badge { display: inline-block; font-size: 0.7rem; font-weight: 600; padding: 2px 10px; border-radius: var(--radius-pill, 999px); text-transform: uppercase; letter-spacing: 0.3px; }
	.badge-enabled { background: #dcfce7; color: #16a34a; }
	.badge-paused { background: #fef3c7; color: #d97706; }
	.badge-removed { background: #f1f5f9; color: #64748b; }
	.badge-fail { background: #fef2f2; color: #dc2626; }
	.tag { display: inline-block; font-size: 0.7rem; font-weight: 600; padding: 2px 10px; border-radius: var(--radius-pill, 999px); }
	.tag-bad { background: #fef2f2; color: #dc2626; }
	.tag-good { background: #dcfce7; color: #16a34a; }
	.tag-neutral { background: #f1f5f9; color: #64748b; }

	/* ── Methodology Steps ── */
	.methodology-steps { display: grid; grid-template-columns: repeat(auto-fill, minmax(130px, 1fr)); gap: 10px; margin: 20px 0; }
	.step { background: var(--bg-subtle, #f6f8fc); border-radius: var(--radius-md, 12px); padding: 14px 10px; text-align: center; font-size: 0.8rem; font-weight: 500; color: var(--text, #0f172a); border: 1px solid var(--border, rgba(15,23,42,0.1)); }
	.step-num { display: block; font-size: 1.3rem; font-weight: 800; color: var(--accent, #0055ff); margin-bottom: 4px; }

	/* ── Recommendations (flat numbered list) ── */
	.rec-list { counter-reset: rec; margin: 24px 0; }
	.rec-item { counter-increment: rec; background: var(--bg-subtle, #f6f8fc); border-radius: var(--radius-md, 12px); padding: 24px 24px 24px 64px; margin-bottom: 12px; position: relative; border: 1px solid var(--border, rgba(15,23,42,0.1)); }
	.rec-item::before { content: counter(rec); position: absolute; left: 20px; top: 24px; font-size: 1.2rem; font-weight: 800; color: var(--accent, #0055ff); background: var(--bg, #fff); width: 30px; height: 30px; border-radius: 8px; display: flex; align-items: center; justify-content: center; border: 1px solid var(--border, rgba(15,23,42,0.1)); }
	.rec-item h4 { margin-bottom: 6px; }
	.rec-item p { font-size: 0.9rem; margin-bottom: 6px; }
	.rec-item p:last-child { margin-bottom: 0; }
	.rec-item ul { margin: 6px 0 0 18px; line-height: 1.6; font-size: 0.9rem; color: var(--text-muted, #525866); }

	/* ── Impact Grid ── */
	.impact-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 16px; }
	.impact-card { background: var(--text, #0f172a); color: #fff; border-radius: var(--radius-md, 12px); padding: 28px 24px; text-align: center; }
	.impact-card h4 { color: #94a3b8; font-size: 0.85rem; text-transform: uppercase; letter-spacing: 0.5px; margin-bottom: 8px; }
	.impact-number { font-size: 2.4rem; font-weight: 800; color: #fff !important; margin-bottom: 4px !important; letter-spacing: -0.02em; }
	.impact-number span { font-size: 0.9rem; font-weight: 400; color: #64748b; }

	/* ── CTA Section ── */
	.cta-section { background: var(--bg-subtle, #f6f8fc); padding: var(--space-section, 4rem) 0 !important; }
	.cta-card { text-align: center; max-width: 600px; margin: 0 auto; }
	.cta-card h2 { justify-content: center; font-size: 1.8rem; }
	.cta-card p { text-align: center; font-size: 1.05rem; }
	.cta-btn { display: inline-flex; align-items: center; gap: 8px; background: var(--accent, #0055ff); color: #fff; border: none; padding: 16px 36px; font-size: 1rem; font-weight: 600; border-radius: var(--radius-pill, 999px); cursor: pointer; transition: all 0.2s var(--ease-out, cubic-bezier(0.22,1,0.36,1)); font-family: inherit; }
	.cta-btn:hover { background: var(--accent-strong, #0040cc); transform: translateY(-1px); box-shadow: var(--shadow-md, 0 12px 40px rgba(15,23,42,0.08)); }

	/* ── Modal ── */
	.modal-overlay { display: none; position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(15,23,42,0.6); backdrop-filter: blur(4px); z-index: 1000; align-items: center; justify-content: center; padding: 24px; }
	.modal-overlay.open { display: flex; }
	.modal-card { background: #fff; border-radius: var(--radius-lg, 16px); max-width: 480px; width: 100%; padding: 48px 40px 40px; position: relative; box-shadow: 0 25px 60px rgba(15,23,42,0.2); animation: modalIn 0.25s var(--ease-out, cubic-bezier(0.22,1,0.36,1)); }
	@keyframes modalIn { from { opacity: 0; transform: scale(0.95) translateY(10px); } to { opacity: 1; transform: scale(1) translateY(0); } }
	.modal-close { position: absolute; top: 16px; right: 16px; background: var(--bg-subtle, #f6f8fc); border: none; width: 32px; height: 32px; border-radius: 50%; font-size: 1.2rem; cursor: pointer; display: flex; align-items: center; justify-content: center; color: var(--text-muted, #525866); transition: all 0.2s; font-family: inherit; }
	.modal-close:hover { background: #e2e8f0; color: var(--text, #0f172a); }
	.modal-body { text-align: center; }
	.modal-icon { font-size: 2.4rem; display: block; margin-bottom: 16px; }
	.modal-card h3 { font-size: 1.4rem; margin: 0 0 8px; }
	.modal-sub { font-size: 0.95rem; margin-bottom: 28px; }
	.modal-options { display: flex; flex-direction: column; gap: 12px; margin-bottom: 20px; }
	.modal-btn { display: flex; align-items: center; justify-content: center; gap: 10px; padding: 14px 24px; border-radius: var(--radius-md, 12px); font-size: 0.95rem; font-weight: 600; text-decoration: none; transition: all 0.2s var(--ease-out, cubic-bezier(0.22,1,0.36,1)); font-family: inherit; }
	.modal-btn-primary { background: var(--accent, #0055ff); color: #fff; border: none; }
	.modal-btn-primary:hover { background: var(--accent-strong, #0040cc); transform: translateY(-1px); }
	.modal-btn-secondary { background: var(--bg-subtle, #f6f8fc); color: var(--text, #0f172a); border: 1px solid var(--border, rgba(15,23,42,0.1)); }
	.modal-btn-secondary:hover { background: #e2e8f0; transform: translateY(-1px); }
	.modal-note { font-size: 0.8rem; color: var(--text-muted, #525866); margin: 0; }

	/* ── Footer ── */
	.report-footer { margin-top: 32px; font-size: 0.8rem; color: var(--text-muted, #525866); text-align: center; border-top: 1px solid var(--border, rgba(15,23,42,0.1)); padding-top: 24px; }

	/* ── Findings List ── */
	.findings-list { list-style: none; padding: 0; margin: 16px 0; }
	.findings-list li { padding: 10px 0; border-bottom: 1px solid var(--border, rgba(15,23,42,0.1)); line-height: 1.6; font-size: 0.92rem; color: var(--text-muted, #525866); }
	.findings-list li:last-child { border-bottom: none; }
	.findings-list li strong { color: var(--text, #0f172a); }

	/* ── Responsive ── */
	@media (max-width: 768px) {
		.report-hero h1 { font-size: 1.6rem; }
		.kpi-grid { grid-template-columns: 1fr 1fr; }
		.kpi-chart-label { flex: 0 0 100px; font-size: 0.78rem; }
		.kpi-chart-val { flex: 0 0 70px; font-size: 0.8rem; }
		.meta-grid { flex-direction: column; gap: 16px; }
		.data-table { font-size: 0.78rem; overflow-x: auto; display: block; border: none; }
		.data-table th, .data-table td { padding: 8px 10px; }
		.info-grid { grid-template-columns: 1fr; }
		.methodology-steps { grid-template-columns: 1fr 1fr; }
		.rec-item { padding: 20px 16px 20px 56px; }
		.rec-item::before { left: 16px; top: 20px; width: 26px; height: 26px; font-size: 1rem; }
	}
</style>
